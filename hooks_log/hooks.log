{"timestamp": "2026-04-24T15:09:24.953062", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/.github/workflows/agent.yml", "old_string": "    with:\n      runner_label: ${{ inputs.runner_label }}\n      issue_number: ${{ inputs.issue_number }}", "new_string": "    with:\n      runner_label:     ${{ inputs.runner_label }}\n      issue_number:     ${{ inputs.issue_number }}\n      cache_key_prefix: ${{ github.repository }}-agent-img", "replace_all": false}, "tool_response": {"filePath": "/workspace/.github/workflows/agent.yml", "oldString": "    with:\n      runner_label: ${{ inputs.runner_label }}\n      issue_number: ${{ inputs.issue_number }}", "newString": "    with:\n      runner_label:     ${{ inputs.runner_label }}\n      issue_number:     ${{ inputs.issue_number }}\n      cache_key_prefix: ${{ github.repository }}-agent-img", "originalFile": "name: Agent\n\n# Consumer caller workflow: demonstrates the shape a real downstream fork\n# ends up with after adopting autopilot from the Marketplace. Consumes\n# coding-agent.yml as a reusable workflow via a cross-repo `uses:` ref \u2014\n# never a local `./` path. The repo boundary is what enforces this: a\n# `./` reference simply cannot resolve across repos, so the separation\n# between implementation (autopilot) and consumer (autopilot-selftest) is\n# mechanical, not conventional.\n#\n# Manual trigger only \u2014 pick an existing issue number and the runner label\n# (your GitHub username) matching your self-hosted runner. Apply the normal\n# merge_into_upstream/timeout/model frontmatter on the issue as usual; this\n# file just hands off to coding-agent.yml.\n#\n# PR testing loop: when there is a PR open against autopilot, flip the\n# `@main` ref below to `@<pr-branch>` to run this repo's pinned test\n# issues against the in-flight implementation, then flip back to `@main`\n# on merge. This is the same one-line edit a downstream contributor makes\n# to smoke-test a version bump, so the flow is dogfooded by design.\n\non:\n  workflow_dispatch:\n    inputs:\n      runner_label:\n        description: GitHub username (matches self-hosted runner label)\n        required: true\n        type: string\n      issue_number:\n        description: Issue number to work on\n        required: true\n        type: string\n\npermissions:\n  contents: write\n  pull-requests: write\n  issues: write\n\njobs:\n  run:\n    uses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\n    with:\n      runner_label: ${{ inputs.runner_label }}\n      issue_number: ${{ inputs.issue_number }}\n    secrets:\n      UPSTREAM_PR_TOKEN: ${{ secrets.UPSTREAM_PR_TOKEN }}\n", "structuredPatch": [{"oldStart": 40, "oldLines": 7, "newStart": 40, "newLines": 8, "lines": ["   run:", "     uses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main", "     with:", "-      runner_label: ${{ inputs.runner_label }}", "-      issue_number: ${{ inputs.issue_number }}", "+      runner_label:     ${{ inputs.runner_label }}", "+      issue_number:     ${{ inputs.issue_number }}", "+      cache_key_prefix: ${{ github.repository }}-agent-img", "     secrets:", "       UPSTREAM_PR_TOKEN: ${{ secrets.UPSTREAM_PR_TOKEN }}"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01GHRgieF2maEvrQu6C5UX8h", "duration_ms": 15}}
