{"timestamp": "2026-04-23T00:05:55.994198", "event": "Edit", "data": {"session_id": "52dd771c-b9eb-4144-8085-1b2d99eb1964", "transcript_path": "/home/node/.claude/projects/-workspace/52dd771c-b9eb-4144-8085-1b2d99eb1964.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/workflows/coding-agent.yml", "old_string": "  image-digest:\n    uses: ./.github/workflows/image-digest.yml", "new_string": "  image-digest:\n    name: digest\n    uses: ./.github/workflows/image-digest.yml", "replace_all": false}, "tool_response": {"filePath": "/workspace/autopilot/.github/workflows/coding-agent.yml", "oldString": "  image-digest:\n    uses: ./.github/workflows/image-digest.yml", "newString": "  image-digest:\n    name: digest\n    uses: ./.github/workflows/image-digest.yml", "originalFile": "name: Coding Agent\n\n# Pure-library reusable workflow: callable only via `uses:` from a consumer\n# caller workflow (see autopilot-selftest for the canonical caller shape).\n# The consumer owns the event trigger (workflow_dispatch, issues labels,\n# etc.); this file is the implementation contract and nothing more.\non:\n  workflow_call:\n    inputs:\n      runner_label:\n        description: GitHub username (matches self-hosted runner label)\n        required: true\n        type: string\n      issue_number:\n        description: Issue number to work on\n        required: true\n        type: string\n      agent_image:\n        description: |\n          Override base image. Accepts any ref docker can pull (tag or digest).\n          If unset, resolves the latest digest of ghcr.io/clockwork-pilot/autopilot-ws.\n        required: false\n        type: string\n        default: \"\"\n      image_setup_script:\n        description: |\n          Optional bash snippet layered onto the base image as root (FROM base / RUN <script>).\n          Use for apt/pip/system-level deps. Workspace is NOT mounted \u2014 this runs at image-build time.\n          Cached by script hash on the runner; re-runs only when the script changes.\n        required: false\n        type: string\n        default: \"\"\n    secrets:\n      UPSTREAM_PR_TOKEN:\n        description: PAT used by open-upstream-pr when merge_into_upstream is true. Optional \u2014 only issues that opt in require it.\n        required: false\n\njobs:\n  fetch-issue:\n    runs-on: ubuntu-latest\n    outputs:\n      title:    ${{ steps.f.outputs.title }}\n      body_raw: ${{ steps.f.outputs.body_raw }}\n    steps:\n      - name: fetch\n        id: f\n        env:\n          GH_TOKEN:     ${{ secrets.GITHUB_TOKEN }}\n          REPO:         ${{ github.repository }}\n          ISSUE_NUMBER: ${{ inputs.issue_number }}\n        run: |\n          J=$(gh api \"repos/$REPO/issues/$ISSUE_NUMBER\")\n          echo \"title=$(echo \"$J\" | jq -r .title)\" >> \"$GITHUB_OUTPUT\"\n          { echo \"body_raw<<EOF_BODY_RAW\"; echo \"$J\" | jq -r '.body // \"\"'; echo \"EOF_BODY_RAW\"; } >> \"$GITHUB_OUTPUT\"\n\n  # Verified by: step_output_checks/parse_issue_output\n  parse-issue:\n    needs: fetch-issue\n    runs-on: ubuntu-latest\n    env:\n      TITLE:        ${{ needs.fetch-issue.outputs.title }}\n      BODY_RAW:     ${{ needs.fetch-issue.outputs.body_raw }}\n      ISSUE_NUMBER: ${{ inputs.issue_number }}\n    outputs:\n      agent_task_text:      ${{ steps.p.outputs.agent_task_text }}\n      pr_branch:            ${{ steps.p.outputs.pr_branch }}\n      base_branch:          ${{ steps.p.outputs.base_branch }}\n      timeout_secs:         ${{ steps.p.outputs.timeout_secs }}\n      model:                ${{ steps.p.outputs.model }}\n      agent_branch_default: ${{ steps.p.outputs.agent_branch_default }}\n      merge_into_upstream:  ${{ steps.p.outputs.merge_into_upstream }}\n    steps:\n      - name: parse\n        id: p\n        run: |\n          TITLE=\"${TITLE:-}\"\n          BODY_RAW=\"${BODY_RAW:-}\"\n          ISSUE_NUMBER_IN=\"${ISSUE_NUMBER:-}\"\n\n          # Strip CR (GitHub issue bodies are CRLF)\n          BODY_RAW=$(printf '%s' \"$BODY_RAW\" | tr -d '\\r')\n\n          BRANCH_SLUG=$(echo \"$TITLE\" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-\\+/-/g;s/^-//;s/-$//' | cut -c1-100)\n\n          # Only strip frontmatter when at least two `---` fences are present;\n          # otherwise sed '0,/---/d' would delete through EOF and wipe the body.\n          DELIM_COUNT=$(printf '%s\\n' \"$BODY_RAW\" | grep -c '^---[[:space:]]*$' || true)\n          if [ \"${DELIM_COUNT:-0}\" -ge 2 ]; then\n            AGENT_TASK_TEXT=$(printf '%s\\n' \"$BODY_RAW\" | sed '0,/^---[[:space:]]*$/d' | sed '0,/^---[[:space:]]*$/d')\n            YAML_PART=$(printf '%s\\n' \"$BODY_RAW\" | sed -n '/^---[[:space:]]*$/,/^---[[:space:]]*$/p' | sed '1d;$d')\n          else\n            AGENT_TASK_TEXT=\"$BODY_RAW\"\n            YAML_PART=\"\"\n          fi\n          PR_BRANCH=\"\"\n          BASE_BRANCH=\"\"\n          TIMEOUT_MINS=\"\"\n          MODEL=\"\"\n          MERGE_INTO_UPSTREAM=\"\"\n          if [ -n \"$YAML_PART\" ]; then\n            PR_BRANCH=$(echo \"$YAML_PART\" | yq -r '.pr_branch // \"\"')\n            BASE_BRANCH=$(echo \"$YAML_PART\" | yq -r '.base_branch // \"\"')\n            TIMEOUT_MINS=$(echo \"$YAML_PART\" | yq -r '.timeout // \"\"')\n            MODEL=$(echo \"$YAML_PART\" | yq -r '.model // \"\"')\n            MERGE_INTO_UPSTREAM=$(echo \"$YAML_PART\" | yq -r '.merge_into_upstream // \"\"')\n          fi\n          [ \"$PR_BRANCH\" = \"null\" ] && PR_BRANCH=\"\"\n          [ \"$BASE_BRANCH\" = \"null\" ] && BASE_BRANCH=\"\"\n          [ \"$TIMEOUT_MINS\" = \"null\" ] && TIMEOUT_MINS=\"\"\n          [ \"$MODEL\" = \"null\" ] && MODEL=\"\"\n          [ \"$MERGE_INTO_UPSTREAM\" = \"null\" ] && MERGE_INTO_UPSTREAM=\"\"\n          # Normalize to \"true\" / \"\" \u2014 only the literal true enables upstream PR.\n          if [ \"$MERGE_INTO_UPSTREAM\" = \"true\" ]; then\n            MERGE_INTO_UPSTREAM=\"true\"\n          else\n            MERGE_INTO_UPSTREAM=\"\"\n          fi\n\n          TIMEOUT_SECS=$(( ${TIMEOUT_MINS:-10} * 60 ))\n          MODEL=\"${MODEL:-claude-haiku-4-5}\"\n          AGENT_BRANCH_DEFAULT=\"agent/${ISSUE_NUMBER_IN}-${BRANCH_SLUG}\"\n\n          : \"${GITHUB_OUTPUT:?GITHUB_OUTPUT must be set}\"\n          echo \"pr_branch=$PR_BRANCH\" >> \"$GITHUB_OUTPUT\"\n          echo \"base_branch=$BASE_BRANCH\" >> \"$GITHUB_OUTPUT\"\n          echo \"timeout_secs=$TIMEOUT_SECS\" >> \"$GITHUB_OUTPUT\"\n          echo \"model=$MODEL\" >> \"$GITHUB_OUTPUT\"\n          echo \"agent_branch_default=$AGENT_BRANCH_DEFAULT\" >> \"$GITHUB_OUTPUT\"\n          echo \"merge_into_upstream=$MERGE_INTO_UPSTREAM\" >> \"$GITHUB_OUTPUT\"\n          echo \"agent_task_text<<EOF_AGENT_TASK_TEXT\" >> \"$GITHUB_OUTPUT\"\n          printf '%s\\n' \"$AGENT_TASK_TEXT\" >> \"$GITHUB_OUTPUT\"\n          echo \"EOF_AGENT_TASK_TEXT\" >> \"$GITHUB_OUTPUT\"\n\n  validate-runner:\n    runs-on: ubuntu-latest\n    steps:\n      - name: Validate runner availability\n        env:\n          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n          RUNNER_LABEL: ${{ inputs.runner_label }}\n        run: |\n          echo \"::group::Validating Runner\"\n          echo \"Checking for self-hosted runner with label: $RUNNER_LABEL\"\n\n          runners=$(gh api repos/${{ github.repository }}/actions/runners \\\n            --jq '.runners[] | select(.labels[].name == \"'$RUNNER_LABEL'\") | .id' 2>/dev/null || echo \"\")\n\n          if [ -z \"$runners\" ]; then\n            echo \"::error::No self-hosted runner found with label '$RUNNER_LABEL'\"\n            echo \"\"\n            echo \"Available runners:\"\n            gh api repos/${{ github.repository }}/actions/runners \\\n              --jq '.runners[] | \"\\(.id): \\(.name) (labels: \\(.labels[].name | join(\", \")))\"' || true\n            exit 1\n          fi\n\n          echo \"\u2713 Found runner(s) with label: $RUNNER_LABEL\"\n          echo \"::endgroup::\"\n\n  gather-repo-facts:\n    runs-on: ubuntu-latest\n    env:\n      GH_TOKEN:     ${{ secrets.GITHUB_TOKEN }}\n      REPO:         ${{ github.repository }}\n      ISSUE_NUMBER: ${{ inputs.issue_number }}\n    outputs:\n      existing_agent_branch: ${{ steps.g.outputs.existing_agent_branch }}\n      default_branch:        ${{ steps.g.outputs.default_branch }}\n    steps:\n      - name: gather\n        id: g\n        run: |\n          EXISTING=$(gh api \"repos/$REPO/branches\" --paginate -q \".[].name\" \\\n            | grep -E \"^agent/$ISSUE_NUMBER(-|$)\" | head -1 || true)\n          DEFAULT=$(gh api \"repos/$REPO\" -q .default_branch)\n          echo \"existing_agent_branch=$EXISTING\" >> \"$GITHUB_OUTPUT\"\n          echo \"default_branch=$DEFAULT\" >> \"$GITHUB_OUTPUT\"\n\n  # Verified by: step_output_checks/choose_branch_output\n  choose-branch:\n    needs: [parse-issue, gather-repo-facts]\n    runs-on: ubuntu-latest\n    env:\n      PR_BRANCH:             ${{ needs.parse-issue.outputs.pr_branch }}\n      AGENT_BRANCH_DEFAULT:  ${{ needs.parse-issue.outputs.agent_branch_default }}\n      EXISTING_AGENT_BRANCH: ${{ needs.gather-repo-facts.outputs.existing_agent_branch }}\n      BASE_FROM_ISSUE:       ${{ needs.parse-issue.outputs.base_branch }}\n      DEFAULT_BRANCH:        ${{ needs.gather-repo-facts.outputs.default_branch }}\n    outputs:\n      branch:      ${{ steps.c.outputs.branch }}\n      base_branch: ${{ steps.c.outputs.base_branch }}\n    steps:\n      - name: choose\n        id: c\n        run: |\n          BRANCH=\"${PR_BRANCH:-${EXISTING_AGENT_BRANCH:-$AGENT_BRANCH_DEFAULT}}\"\n          BASE=\"${BASE_FROM_ISSUE:-$DEFAULT_BRANCH}\"\n          echo \"branch=$BRANCH\" >> \"$GITHUB_OUTPUT\"\n          echo \"base_branch=$BASE\" >> \"$GITHUB_OUTPUT\"\n\n  # Always runs (cheap: one `docker manifest inspect` call). Its output is\n  # ignored when inputs.agent_image is set \u2014 prepare-image picks the override\n  # in that case. Keeping it unconditional means every downstream job can rely\n  # on the default success() gate instead of custom skip-tolerant conditions.\n  image-digest:\n    uses: ./.github/workflows/image-digest.yml\n\n  # Picks the base image (user override or resolved digest) and, if\n  # image_setup_script is set, builds a thin derived image on the runner\n  # (FROM base / RUN <script>) tagged by sha256 of the script so repeat runs\n  # reuse docker's layer cache. Emits the final image ref for run-agent.\n  prepare-image:\n    needs: [validate-runner, image-digest]\n    runs-on: [self-hosted, \"${{ inputs.runner_label }}\"]\n    outputs:\n      image: ${{ steps.prep.outputs.image }}\n    steps:\n      - name: Resolve and prepare image\n        id: prep\n        env:\n          USER_AGENT_IMAGE:   ${{ inputs.agent_image }}\n          RESOLVED_IMAGE:     ${{ needs.image-digest.outputs.image }}\n          IMAGE_SETUP_SCRIPT: ${{ inputs.image_setup_script }}\n        run: |\n          set -euo pipefail\n\n          BASE=\"${USER_AGENT_IMAGE:-$RESOLVED_IMAGE}\"\n          if [ -z \"$BASE\" ]; then\n            echo \"::error::Could not determine base image \u2014 both inputs.agent_image and image-digest output are empty\"\n            exit 1\n          fi\n\n          if [ -z \"$IMAGE_SETUP_SCRIPT\" ]; then\n            echo \"::notice::No image_setup_script provided \u2014 using base image as-is: $BASE\"\n            echo \"image=$BASE\" >> \"$GITHUB_OUTPUT\"\n            exit 0\n          fi\n\n          CTX=$(mktemp -d)\n          trap 'rm -rf \"$CTX\"' EXIT\n\n          printf '%s' \"$IMAGE_SETUP_SCRIPT\" > \"$CTX/setup.sh\"\n          chmod +x \"$CTX/setup.sh\"\n          SCRIPT_HASH=$(sha256sum \"$CTX/setup.sh\" | cut -c1-16)\n          BASE_HASH=$(printf '%s' \"$BASE\" | sha256sum | cut -c1-16)\n          TAG=\"autopilot-prepared:${BASE_HASH}-${SCRIPT_HASH}\"\n\n          cat > \"$CTX/Dockerfile\" <<EOF\n          # syntax=docker/dockerfile:1\n          FROM $BASE\n          USER 0\n          COPY setup.sh /tmp/autopilot-setup.sh\n          RUN bash /tmp/autopilot-setup.sh && rm /tmp/autopilot-setup.sh\n          # Drop back to the image's default user (image-defined USER directive\n          # is preserved across FROM, so this reassertion is explicit, not new).\n          USER node\n          EOF\n\n          echo \"::notice::Building prepared image $TAG from $BASE (script hash: $SCRIPT_HASH)\"\n          docker build -t \"$TAG\" \"$CTX\"\n          echo \"image=$TAG\" >> \"$GITHUB_OUTPUT\"\n\n  run-agent:\n    needs: [validate-runner, fetch-issue, parse-issue, choose-branch, image-digest, prepare-image]\n    runs-on: [self-hosted, \"${{ inputs.runner_label }}\"]\n    outputs:\n      has_new_commit:  ${{ steps.detect-new-commit.outputs.has_new_commit }}\n      agent_exit_code: ${{ steps.agent.outputs.exit_code }}\n      constraints_md:  ${{ steps.constraints-out.outputs.body }}\n      commit_msg:      ${{ steps.commit-msg.outputs.body }}\n    permissions:\n      contents: write\n    steps:\n      - name: Checkout repo into isolated workspace\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          fetch-depth: 0\n          persist-credentials: true\n\n      - name: Checkout work branch\n        env:\n          BRANCH:      ${{ needs.choose-branch.outputs.branch }}\n          BASE_BRANCH: ${{ needs.choose-branch.outputs.base_branch }}\n        run: |\n          git fetch origin\n          if git show-ref --verify --quiet \"refs/remotes/origin/$BRANCH\"; then\n            echo \"::notice::Resuming existing work branch: $BRANCH\"\n            git checkout -B \"$BRANCH\" \"origin/$BRANCH\"\n          else\n            echo \"::notice::Creating new work branch: $BRANCH (base: $BASE_BRANCH)\"\n            git checkout -B \"$BRANCH\" \"origin/$BASE_BRANCH\"\n          fi\n\n      - name: Prepare docker-files directories\n        run: |\n          # DOCKER_FILES must be set in the self-hosted runner's service env\n          # (e.g. actions-runner/.env). It points at the host dir holding\n          # persistent Claude credentials/cargo caches mounted into the agent.\n          : \"${DOCKER_FILES:?DOCKER_FILES not set in runner env \u2014 configure it in the runner service env (actions-runner/.env)}\"\n          mkdir -p \"$DOCKER_FILES/.credentials\" \"$DOCKER_FILES/.cargo\" \"$DOCKER_FILES/.local\"\n          [ -s \"$DOCKER_FILES/.claude.local.json\" ] || printf '{}\\n' > \"$DOCKER_FILES/.claude.local.json\"\n\n      # Image is either (a) locally built by prepare-image, or (b) a registry\n      # ref. docker run will pull (b) lazily; (a) is already present. No login\n      # needed for the default ghcr.io/clockwork-pilot/autopilot-ws (public).\n      # If a user's custom agent_image is private, they must configure a docker\n      # login step earlier in their own caller workflow.\n\n      - name: Run Claude agent in Docker\n        id: agent\n        env:\n          MODEL:        ${{ needs.parse-issue.outputs.model }}\n          TIMEOUT_SECS: ${{ needs.parse-issue.outputs.timeout_secs }}\n          PROMPT:       ${{ needs.parse-issue.outputs.agent_task_text }}\n          AGENT_IMAGE:  ${{ needs.prepare-image.outputs.image }}\n        run: |\n          echo \"::group::Claude Agent Output\"\n          set +e\n          bash .github/scripts/run-in-docker-claude.sh\n          EXIT_CODE=$?\n          echo \"::endgroup::\"\n          echo \"exit_code=$EXIT_CODE\" >> \"$GITHUB_OUTPUT\"\n          set -e\n\n      - name: Run constraint checks\n        id: constraints\n        if: always()\n        env:\n          AGENT_IMAGE: ${{ needs.prepare-image.outputs.image }}\n        run: |\n          # stdout \u2192 issue comment; exit code gates the commit step.\n          set +e\n          bash .github/scripts/run-in-docker-no-claude.sh \\\n            'check_spec_constraints.py --dry-run' \\\n            > /tmp/constraints.md 2>&1\n          EXIT_CODE=$?\n          set -e\n          echo \"exit_code=$EXIT_CODE\" >> \"$GITHUB_OUTPUT\"\n\n      - name: Export constraints report as job output\n        id: constraints-out\n        if: always()\n        run: |\n          {\n            echo \"body<<EOF_CONSTRAINTS_BODY\"\n            cat /tmp/constraints.md 2>/dev/null || echo \"(no constraints report produced)\"\n            echo \"EOF_CONSTRAINTS_BODY\"\n          } >> \"$GITHUB_OUTPUT\"\n\n      - name: Record HEAD before commit\n        id: head-before\n        if: always()\n        run: echo \"sha=$(git rev-parse HEAD)\" >> \"$GITHUB_OUTPUT\"\n\n      - name: Agent commit\n        id: agent-commit\n        if: always() && steps.agent.outputs.exit_code == '0' && steps.constraints.outputs.exit_code == '0'\n        env:\n          MODEL:       ${{ needs.parse-issue.outputs.model }}\n          PROMPT:      commit changes\n          AGENT_IMAGE: ${{ needs.prepare-image.outputs.image }}\n        run: bash .github/scripts/run-in-docker-claude.sh --allow-git-commit || true\n\n      - name: Detect new commit\n        id: detect-new-commit\n        if: always()\n        run: |\n          if [ \"${{ steps.head-before.outputs.sha }}\" != \"$(git rev-parse HEAD)\" ]; then\n            echo \"has_new_commit=true\" >> \"$GITHUB_OUTPUT\"\n          else\n            echo \"has_new_commit=false\" >> \"$GITHUB_OUTPUT\"\n          fi\n\n      - name: Push branch\n        if: steps.detect-new-commit.outputs.has_new_commit == 'true'\n        env:\n          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n        run: |\n          BRANCH=\"${{ needs.choose-branch.outputs.branch }}\"\n          git push origin \"$BRANCH\"\n\n      - name: Capture last commit message for PR body\n        id: commit-msg\n        if: steps.detect-new-commit.outputs.has_new_commit == 'true'\n        run: |\n          {\n            echo \"body<<EOF_COMMIT_BODY\"\n            git log -1 --pretty=%B HEAD\n            echo \"EOF_COMMIT_BODY\"\n          } >> \"$GITHUB_OUTPUT\"\n\n  # Fork-PR creation and issue commenting split off the self-hosted runner.\n  # Only needs GITHUB_TOKEN; does not require the agent runner or Docker.\n  open-pr:\n    needs: [fetch-issue, parse-issue, choose-branch, run-agent]\n    # Handles: (a) fork-PR flow end-to-end, and (b) issue commenting for the\n    # upstream-no-commit case (where open-upstream-pr is gated off). The\n    # upstream-with-commit case is owned by open-upstream-pr.\n    if: |\n      always() && needs.run-agent.result != 'skipped' && needs.run-agent.result != 'cancelled'\n      && (needs.parse-issue.outputs.merge_into_upstream != 'true'\n          || needs.run-agent.outputs.has_new_commit != 'true')\n    runs-on: ubuntu-latest\n    permissions:\n      pull-requests: write\n      issues: write\n    steps:\n      - name: Check out repo (for composite actions)\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          persist-credentials: false\n\n      - name: Open PR inside fork\n        if: needs.run-agent.outputs.has_new_commit == 'true' && needs.parse-issue.outputs.merge_into_upstream != 'true'\n        uses: ./.github/actions/create-pr\n        with:\n          gh-token:    ${{ secrets.GITHUB_TOKEN }}\n          pr-repo:     ${{ github.repository }}\n          pr-head:     ${{ needs.choose-branch.outputs.branch }}\n          pr-title:    ${{ needs.fetch-issue.outputs.title }}\n          issue-ref:   ${{ github.repository }}#${{ inputs.issue_number }}\n          commit-body: ${{ needs.run-agent.outputs.commit_msg }}\n\n      - name: Comment agent result on issue\n        uses: ./.github/actions/comment-agent-result\n        with:\n          gh-token:        ${{ secrets.GITHUB_TOKEN }}\n          repo:            ${{ github.repository }}\n          issue-number:    ${{ inputs.issue_number }}\n          constraints-md:  ${{ needs.run-agent.outputs.constraints_md }}\n          has-new-commit:  ${{ needs.run-agent.outputs.has_new_commit }}\n          agent-exit-code: ${{ needs.run-agent.outputs.agent_exit_code }}\n\n  # Cross-repo PR from fork \u2192 upstream. Isolated on a GitHub-hosted runner so\n  # UPSTREAM_PR_TOKEN never enters the self-hosted agent job. The `upstream-pr`\n  # environment must exist in fork settings with UPSTREAM_PR_TOKEN set;\n  # see autopilot-ws/README.md \"Opening PRs against the upstream repo\".\n  open-upstream-pr:\n    needs: [fetch-issue, parse-issue, choose-branch, run-agent]\n    if: needs.run-agent.outputs.has_new_commit == 'true' && needs.parse-issue.outputs.merge_into_upstream == 'true'\n    runs-on: ubuntu-latest\n    environment: upstream-pr\n    permissions:\n      contents: read\n      issues: write\n    steps:\n      - name: Check out repo (for composite actions)\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          persist-credentials: false\n\n      - name: Resolve upstream repo\n        id: upstream\n        env:\n          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n        run: |\n          UPSTREAM=$(gh api \"repos/${{ github.repository }}\" -q '.parent.full_name // \"\"')\n          if [ -z \"$UPSTREAM\" ]; then\n            echo \"::error::merge_into_upstream: true but ${{ github.repository }} has no parent (not a fork)\"\n            exit 1\n          fi\n          echo \"full_name=$UPSTREAM\" >> \"$GITHUB_OUTPUT\"\n\n      - name: Ensure UPSTREAM_PR_TOKEN is configured\n        env:\n          UPSTREAM_PR_TOKEN: ${{ secrets.UPSTREAM_PR_TOKEN }}\n        run: |\n          : \"${UPSTREAM_PR_TOKEN:?UPSTREAM_PR_TOKEN is not set in the 'upstream-pr' environment \u2014 see autopilot-ws/README.md 'Opening PRs against the upstream repo (optional)'}\"\n\n      - name: Open PR against upstream\n        uses: ./.github/actions/create-pr\n        with:\n          gh-token:    ${{ secrets.UPSTREAM_PR_TOKEN }}\n          pr-repo:     ${{ steps.upstream.outputs.full_name }}\n          pr-head:     ${{ github.repository_owner }}:${{ needs.choose-branch.outputs.branch }}\n          pr-title:    ${{ needs.fetch-issue.outputs.title }}\n          issue-ref:   ${{ github.repository }}#${{ inputs.issue_number }}\n          commit-body: ${{ needs.run-agent.outputs.commit_msg }}\n\n      - name: Comment agent result on issue\n        uses: ./.github/actions/comment-agent-result\n        with:\n          gh-token:        ${{ secrets.GITHUB_TOKEN }}\n          repo:            ${{ github.repository }}\n          issue-number:    ${{ inputs.issue_number }}\n          constraints-md:  ${{ needs.run-agent.outputs.constraints_md }}\n          has-new-commit:  ${{ needs.run-agent.outputs.has_new_commit }}\n          agent-exit-code: ${{ needs.run-agent.outputs.agent_exit_code }}\n", "structuredPatch": [{"oldStart": 203, "oldLines": 6, "newStart": 203, "newLines": 7, "lines": ["   # in that case. Keeping it unconditional means every downstream job can rely", "   # on the default success() gate instead of custom skip-tolerant conditions.", "   image-digest:", "+    name: digest", "     uses: ./.github/workflows/image-digest.yml", " ", "   # Picks the base image (user override or resolved digest) and, if"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01X5F6U5sfLbU3hZHZfDHzqs"}}
