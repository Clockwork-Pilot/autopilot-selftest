{"timestamp": "2026-04-26T12:29:05.609159", "event": "Write", "data": {"session_id": "7a1f01a6-1a9b-4c52-a425-29713aa330f7", "transcript_path": "/home/node/.claude/projects/-workspace/7a1f01a6-1a9b-4c52-a425-29713aa330f7.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/ensure-image-hosted/action.yml", "content": "name: Ensure Image (GitHub-hosted runner)\ndescription: |\n  Prepare a local docker image tag on a GitHub-hosted runner. The runner is\n  ephemeral, so layer/tag state does not persist across runs \u2014 caching is done\n  via GHA-side caches (Buildx `type=gha` for builds, `actions/cache` over a\n  `docker save` tarball for pulls).\n\n  Two paths:\n    - dockerfile unset  \u2192 pulls `base_image`, tags it locally, outputs the tag.\n    - dockerfile set    \u2192 builds the Dockerfile on top of `base_image`.\n\n  Use this action when `runs-on: ubuntu-latest` (or any GitHub-hosted runner).\n  For self-hosted runners use ensure-image-local instead.\n\ninputs:\n  dockerfile:\n    description: Path to the Dockerfile, relative to $GITHUB_WORKSPACE. Leave empty to only pull+tag `base_image`.\n    required: false\n    default: \"\"\n  context:\n    description: Build context directory, relative to $GITHUB_WORKSPACE. Only used when `dockerfile` is set.\n    required: false\n    default: \".\"\n  build_args:\n    description: Newline-separated KEY=VALUE build args, forwarded to the builder. Included in the content hash, so a change invalidates the local tag.\n    required: false\n    default: \"\"\n  base_image:\n    description: Image reference to pull and tag locally, and the FROM contract for any Dockerfile. The action does NOT rewrite the Dockerfile's FROM.\n    required: true\n  tag_prefix:\n    description: |\n      REQUIRED. Project namespace. Dual-purpose:\n        - Docker tag: produced local tag is `<tag_prefix>:<hash>`.\n        - GHA cache scope: scopes the buildx layer cache (`type=gha,scope=<tag_prefix>-buildimg`)\n          and the actions/cache pull-tarball key (`<tag_prefix>-pullimg-<digest>`).\n      Distinct projects MUST use distinct prefixes.\n    required: true\n\noutputs:\n  image:\n    description: Fully qualified local tag of the produced image.\n    value: ${{ steps.finalize.outputs.image }}\n  cache_hit:\n    description: '\"true\" if the local tag pre-existed and neither build nor pull ran.'\n    value: ${{ steps.finalize.outputs.cache_hit }}\n  digest:\n    description: Local image ID (sha256) of the produced image.\n    value: ${{ steps.finalize.outputs.digest }}\n\nruns:\n  using: composite\n  steps:\n    - id: base\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n      run: |\n        set -euo pipefail\n        DIGEST=$(docker manifest inspect \"$BASE\" 2>/dev/null | sha256sum | cut -c1-16) || DIGEST=\"\"\n        if [ -z \"$DIGEST\" ]; then\n          docker pull \"$BASE\" >/dev/null\n          DIGEST=$(docker inspect --format='{{.Id}}' \"$BASE\" | sed 's/^sha256://' | cut -c1-16)\n        fi\n        echo \"digest=$DIGEST\" >> \"$GITHUB_OUTPUT\"\n\n    - id: key\n      shell: bash\n      env:\n        DOCKERFILE:  ${{ inputs.dockerfile }}\n        BUILD_ARGS:  ${{ inputs.build_args }}\n        BASE_DIGEST: ${{ steps.base.outputs.digest }}\n        PREFIX:      ${{ inputs.tag_prefix }}\n      run: |\n        set -euo pipefail\n        if [ -z \"$PREFIX\" ]; then\n          echo \"::error::tag_prefix is required\"\n          exit 1\n        fi\n        SAFE_PREFIX=$(printf '%s' \"$PREFIX\" | tr '/ ' '__' | tr '[:upper:]' '[:lower:]')\n        if [ -z \"$DOCKERFILE\" ]; then\n          HASH=\"base-${BASE_DIGEST}\"\n        else\n          DF_HASH=$(sha256sum \"$DOCKERFILE\" | cut -c1-16)\n          ARG_HASH=$(printf '%s' \"$BUILD_ARGS\" | sha256sum | cut -c1-16)\n          HASH=\"${DF_HASH}-${BASE_DIGEST}-${ARG_HASH}\"\n        fi\n        echo \"hash=$HASH\"                                           >> \"$GITHUB_OUTPUT\"\n        echo \"tag=${SAFE_PREFIX}:${HASH}\"                           >> \"$GITHUB_OUTPUT\"\n        echo \"build_scope=${SAFE_PREFIX}-buildimg\"                  >> \"$GITHUB_OUTPUT\"\n        echo \"pull_cache_key=${SAFE_PREFIX}-pullimg-${BASE_DIGEST}\" >> \"$GITHUB_OUTPUT\"\n\n    - id: local\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        if docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          echo \"hit=true\"  >> \"$GITHUB_OUTPUT\"\n        else\n          echo \"hit=false\" >> \"$GITHUB_OUTPUT\"\n        fi\n\n    # PATH A \u2014 pull+tag base\n    - id: pull-cache\n      if: inputs.dockerfile == '' && steps.local.outputs.hit != 'true'\n      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n      with:\n        path: /tmp/ensure-docker-image.tar\n        key:  ${{ steps.key.outputs.pull_cache_key }}\n\n    - name: Load pulled image from cache\n      if: inputs.dockerfile == '' && steps.local.outputs.hit != 'true' && steps.pull-cache.outputs.cache-hit == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        set -euo pipefail\n        out=$(docker load < /tmp/ensure-docker-image.tar)\n        echo \"$out\"\n        if ! docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          src=$(printf '%s\\n' \"$out\" | sed -n -e 's/^Loaded image: //p' -e 's/^Loaded image ID: //p' | head -n1)\n          [ -n \"$src\" ] && docker tag \"$src\" \"$TAG\"\n        fi\n\n    - name: Pull base image\n      if: inputs.dockerfile == '' && steps.local.outputs.hit != 'true' && steps.pull-cache.outputs.cache-hit != 'true'\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n        TAG:  ${{ steps.key.outputs.tag }}\n      run: |\n        set -euo pipefail\n        docker pull \"$BASE\"\n        docker tag \"$BASE\" \"$TAG\"\n        docker save \"$TAG\" > /tmp/ensure-docker-image.tar\n\n    # PATH B \u2014 build Dockerfile on top of base\n    - if: inputs.dockerfile != '' && steps.local.outputs.hit != 'true'\n      uses: docker/setup-buildx-action@4d04d5d9486b7bd6fa91e7baf45bbb4f8b9deedd\n\n    - name: Build with GHA layer cache\n      if: inputs.dockerfile != '' && steps.local.outputs.hit != 'true'\n      uses: docker/build-push-action@bcafcacb16a39f128d818304e6c9c0c18556b85f\n      with:\n        context:    ${{ inputs.context }}\n        file:       ${{ inputs.dockerfile }}\n        build-args: ${{ inputs.build_args }}\n        tags:       ${{ steps.key.outputs.tag }}\n        load:       true\n        push:       false\n        cache-from: type=gha,scope=${{ steps.key.outputs.build_scope }}\n        cache-to:   type=gha,mode=max,scope=${{ steps.key.outputs.build_scope }}\n\n    - id: finalize\n      shell: bash\n      env:\n        TAG:       ${{ steps.key.outputs.tag }}\n        LOCAL_HIT: ${{ steps.local.outputs.hit }}\n      run: |\n        set -euo pipefail\n        DIGEST=$(docker inspect --format='{{.Id}}' \"$TAG\")\n        {\n          echo \"image=$TAG\"\n          echo \"cache_hit=$LOCAL_HIT\"\n          echo \"digest=$DIGEST\"\n        } >> \"$GITHUB_OUTPUT\"\n"}, "tool_use_id": "toolu_012jF49RHqef3bQc9hTAv3JX"}}
