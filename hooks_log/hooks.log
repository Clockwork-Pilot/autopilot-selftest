   image: ${{ steps.image.outputs.image }}", "originalFile": "name: Check Constraints (with Dockerfile)\n\n# Companion to check-constraints.yml: exercises the `dockerfile` input path\n# through the Clockwork-Pilot/autopilot check-constraints action, proving\n# that consumers can build their own check image (e.g. with jq or other\n# tools not in the base autopilot-ws) and still run constraints against it.\n#\n# The sibling workflow (check-constraints.yml) covers the default path\n# where no Dockerfile is passed and the base autopilot-ws image is pulled.\non:\n  push:\n    branches:\n      - main\n  pull_request:\n\njobs:\n  check-constraints:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          submodules: recursive\n      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main\n        with:\n          dockerfile:       Dockerfile.agent-sample\n          cache_key_prefix: ${{ github.repository }}-check-img\n", "structuredPatch": [{"oldStart": 20, "oldLines": 7, "newStart": 20, "newLines": 13, "lines": ["       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd", "         with:", "           submodules: recursive", "-      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main", "+      - id: image", "+        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main", "         with:", "           dockerfile:       Dockerfile.agent-sample", "+          base_image:       ghcr.io/clockwork-pilot/autopilot-ws:latest", "+          tag:              autopilot-check", "           cache_key_prefix: ${{ github.repository }}-check-img", "+      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main", "+        with:", "+          image: ${{ steps.image.outputs.image }}"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01SE8jfH7wy3xVTFCc4kJVjj", "duration_ms": 15}}
