be missing at constraint-check time.\n        required: false\n        type: string\n        default: \"\"\n      base_image:\n        description: |\n          Autopilot-ws-compatible runtime image the check runs against.\n          Pulled + tagged when `dockerfile` is unset; used as FROM contract\n          when set. Consumer caller supplies this \u2014 autopilot carries no\n          built-in registry ref.\n        required: true\n        type: string\n      dockerfile:\n        description: |\n          Optional Dockerfile path. When unset, the check runs against\n          `base_image` as-is. When set, a derived image is built from\n          `base_image` and the check runs against that.\n        required: false\n        type: string\n        default: \"\"\n      build_args:\n        description: Newline-separated KEY=VALUE build args, forwarded to ensure-docker-image.\n        required: false\n        type: string\n        default: \"\"\n      tag_prefix:\n        description: |\n          REQUIRED. Project tag/cache namespace. See\n          .github/actions/ensure-docker-image/README.md for the dual\n          role (tag partition + Buildx GHA cache scope).\n          Use e.g. `<owner>/<repo>-check-img` (i.e. github.repository + a suffix).\n        required: true\n        type: string\n      extra_docker_args:\n        description: Extra args spliced into `docker run` for the check container.\n        required: false\n        type: string\n        default: \"\"\n\njobs:\n  check-constraints:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          submodules: ${{ inputs.submodules }}\n\n      - id: image\n        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main\n        with:\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          base_image:       ${{ inputs.base_image }}\n          tag:              autopilot-check\n          tag_prefix:       ${{ inputs.tag_prefix }}\n\n      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main\n        with:\n          image: ${{ steps.image.outputs.image }}\n", "structuredPatch": [{"oldStart": 70, "oldLines": 4, "newStart": 70, "newLines": 5, "lines": [" ", "       - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main", "         with:", "-          image: ${{ steps.image.outputs.image }}", "+          image:             ${{ steps.image.outputs.image }}", "+          extra_docker_args: ${{ inputs.extra_docker_args }}"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01XXKcxy3D4zKKYjZTvmqxFf", "duration_ms": 12}}
