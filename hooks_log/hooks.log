nned by\n# digest, or available to pooled/ephemeral self-hosted runners. For single\n# self-hosted runner setups, prefer passing `dockerfile:` directly to the\n# agent workflow \u2014 see autopilot/README.md \u2192 Installing extra dependencies.\n#\n# Start from the pinned autopilot base image and layer in your dependencies.\n# Pin to a digest (`@sha256:...`) rather than `:latest` for reproducibility.", "originalFile": "# Template for building your own agent image.\n#\n# Start from the pinned autopilot base image and layer in your dependencies.\n# The RUN block below is where you'd paste the contents of an\n# `image_setup_script` that has outgrown being inlined in the caller workflow.\n#\n# Pin to a digest (`@sha256:...`) rather than `:latest` for reproducibility.\n# Look up the current digest with:\n#   docker manifest inspect ghcr.io/clockwork-pilot/autopilot-ws:latest \\\n#     | jq -r '.manifests[0].digest // .config.digest'\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\n\nUSER 0\n\nRUN set -euo pipefail \\\n && apt-get update \\\n && apt-get install -y --no-install-recommends \\\n      # add your system packages here, e.g.:\n      # ffmpeg \\\n      # libsndfile1 \\\n      ca-certificates \\\n && rm -rf /var/lib/apt/lists/*\n\n# The base image defines USER node; restate it here so any future edits that\n# add RUN layers above this line can't accidentally leave the image running as\n# root. coding-agent.yml relies on the container default being unprivileged.\nUSER node\n", "structuredPatch": [{"oldStart": 1, "oldLines": 9, "newStart": 1, "newLines": 11, "lines": ["-# Template for building your own agent image.", "+# Template for building your own agent image and pushing it to a registry.", " #", "-# Start from the pinned autopilot base image and layer in your dependencies.", "-# The RUN block below is where you'd paste the contents of an", "-# `image_setup_script` that has outgrown being inlined in the caller workflow.", "+# Use this path when you want an image shared across many repos, pinned by", "+# digest, or available to pooled/ephemeral self-hosted runners. For single", "+# self-hosted runner setups, prefer passing `dockerfile:` directly to the", "+# agent workflow \u2014 see autopilot/README.md \u2192 Installing extra dependencies.", " #", "+# Start from the pinned autopilot base image and layer in your dependencies.", " # Pin to a digest (`@sha256:...`) rather than `:latest` for reproducibility.", " # Look up the current digest with:", " #   docker manifest inspect ghcr.io/clockwork-pilot/autopilot-ws:latest \\"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_016kqL42x5G3XohzHBWAKzf3", "duration_ms": 21}}
