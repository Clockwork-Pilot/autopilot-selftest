eout for the docker run.\" }\n  extra_docker_args: { required: false, default: \"\",    description: \"Extra args spliced into docker run (forwarded as EXTRA_DOCKER_ARGS).\" }\n\noutputs:\n  exit_code: { description: \"Agent process exit code.\", value: \"${{ steps.a.outputs.exit_code }}\" }\n\nruns:\n  using: composite\n  steps:\n    - id: a\n      shell: bash\n      env:\n        MODEL:                    ${{ inputs.model }}\n        PROMPT:                   ${{ inputs.prompt }}\n        AGENT_IMAGE:              ${{ inputs.agent_image }}\n        TIMEOUT_SECS:             ${{ inputs.timeout_secs }}\n        EXTRA_DOCKER_ARGS: ${{ inputs.extra_docker_args }}\n      run: |\n        echo \"::group::Agent Output\"\n        set +e\n        bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-claude.sh\"\n        EXIT_CODE=$?\n        echo \"::endgroup::\"\n        echo \"exit_code=$EXIT_CODE\" >> \"$GITHUB_OUTPUT\"\n        exit \"$EXIT_CODE\"\n", "structuredPatch": [{"oldStart": 7, "oldLines": 6, "newStart": 7, "newLines": 7, "lines": ["   agent_image:       { required: true,  description: \"Local docker tag prepared by ensure-docker-image.\" }", "   timeout_secs:      { required: false, default: \"180\", description: \"Hard timeout for the docker run.\" }", "   extra_docker_args: { required: false, default: \"\",    description: \"Extra args spliced into docker run (forwarded as EXTRA_DOCKER_ARGS).\" }", "+  allow_git_commit:  { required: false, default: \"false\", description: \"If 'true', drop the proxy wrapper so the agent can run git commit.\" }", " ", " outputs:", "   exit_code: { description: \"Agent process exit code.\", value: \"${{ steps.a.outputs.exit_code }}\" }"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01M94w4E23BcztK9pnuCwuj4", "duration_ms": 9}}
