[\"config\"][\"digest\"])\n        ')\n        echo \"image=$IMAGE_REPO@$digest\" >> \"$GITHUB_OUTPUT\"", "newString": "    - id: fetch\n      shell: bash\n      env:\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        set -e\n        manifest=$(docker manifest inspect \"$IMAGE_REPO:latest\")\n        {\n          echo \"manifest_json<<EOF_MANIFEST\"\n          echo \"$manifest\"\n          echo \"EOF_MANIFEST\"\n        } >> \"$GITHUB_OUTPUT\"\n\n    - id: digest\n      uses: ./.github/actions/parse-digest\n      with:\n        manifest_json: ${{ steps.fetch.outputs.manifest_json }}\n        image_repo:    ${{ inputs.image_repo }}", "originalFile": "name: check-constraints\ndescription: Run check_spec_constraints.py against the caller's checked-out workspace, using the autopilot-ws docker image.\n\ninputs:\n  image_repo:\n    description: Registry repo for the constraint-check toolchain image.\n    required: false\n    default: ghcr.io/clockwork-pilot/autopilot-ws\n  command:\n    description: Command to run inside the image. Default runs the constraint checker.\n    required: false\n    default: check_spec_constraints.py\n\nruns:\n  using: composite\n  steps:\n    - id: digest\n      shell: bash\n      env:\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        set -e\n        manifest=$(docker manifest inspect \"$IMAGE_REPO:latest\")\n        digest=$(echo \"$manifest\" | python3 -c '\n        import json, sys\n        m = json.load(sys.stdin)\n        print(m.get(\"manifests\", [{}])[0].get(\"digest\") or m[\"config\"][\"digest\"])\n        ')\n        echo \"image=$IMAGE_REPO@$digest\" >> \"$GITHUB_OUTPUT\"\n\n    - id: cache\n      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n      with:\n        path: /tmp/autopilot-ws.tar\n        key: docker-autopilot-ws-${{ steps.digest.outputs.image }}\n\n    - id: load\n      shell: bash\n      if: steps.cache.outputs.cache-hit == 'true'\n      run: docker load < /tmp/autopilot-ws.tar\n\n    - id: pull\n      shell: bash\n      if: steps.cache.outputs.cache-hit != 'true'\n      env:\n        AGENT_IMAGE: ${{ steps.digest.outputs.image }}\n      run: |\n        docker pull \"$AGENT_IMAGE\"\n        docker save \"$AGENT_IMAGE\" > /tmp/autopilot-ws.tar\n\n    - id: run\n      shell: bash\n      env:\n        AGENT_IMAGE: ${{ steps.digest.outputs.image }}\n        CMD: ${{ inputs.command }}\n      run: bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-no-claude.sh\" \"$CMD\"\n", "structuredPatch": [{"oldStart": 14, "oldLines": 20, "newStart": 14, "newLines": 25, "lines": [" runs:", "   using: composite", "   steps:", "-    - id: digest", "+    - id: fetch", "       shell: bash", "       env:", "         IMAGE_REPO: ${{ inputs.image_repo }}", "       run: |", "         set -e", "         manifest=$(docker manifest inspect \"$IMAGE_REPO:latest\")", "-        digest=$(echo \"$manifest\" | python3 -c '", "-        import json, sys", "-        m = json.load(sys.stdin)", "-        print(m.get(\"manifests\", [{}])[0].get(\"digest\") or m[\"config\"][\"digest\"])", "-        ')", "-        echo \"image=$IMAGE_REPO@$digest\" >> \"$GITHUB_OUTPUT\"", "+        {", "+          echo \"manifest_json<<EOF_MANIFEST\"", "+          echo \"$manifest\"", "+          echo \"EOF_MANIFEST\"", "+        } >> \"$GITHUB_OUTPUT\"", " ", "+    - id: digest", "+      uses: ./.github/actions/parse-digest", "+      with:", "+        manifest_json: ${{ steps.fetch.outputs.manifest_json }}", "+        image_repo:    ${{ inputs.image_repo }}", "+", "     - id: cache", "       uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830", "       with:"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01HFmyJYXTng43puNXtoausa"}}
