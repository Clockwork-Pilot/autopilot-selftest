{"timestamp": "2026-04-23T00:07:17.268867", "event": "Edit", "data": {"session_id": "52dd771c-b9eb-4144-8085-1b2d99eb1964", "transcript_path": "/home/node/.claude/projects/-workspace/52dd771c-b9eb-4144-8085-1b2d99eb1964.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/workflows/check-constraints.yml", "old_string": "jobs:\n  image-digest:\n    name: digest\n    uses: ./.github/workflows/image-digest.yml\n\n  check-constraints:\n    name: check\n    needs: [image-digest]\n    runs-on: ubuntu-latest", "new_string": "jobs:\n  image-digest:\n    uses: ./.github/workflows/image-digest.yml\n\n  check-constraints:\n    needs: [image-digest]\n    runs-on: ubuntu-latest", "replace_all": false}, "tool_response": {"filePath": "/workspace/autopilot/.github/workflows/check-constraints.yml", "oldString": "jobs:\n  image-digest:\n    name: digest\n    uses: ./.github/workflows/image-digest.yml\n\n  check-constraints:\n    name: check\n    needs: [image-digest]\n    runs-on: ubuntu-latest", "newString": "jobs:\n  image-digest:\n    uses: ./.github/workflows/image-digest.yml\n\n  check-constraints:\n    needs: [image-digest]\n    runs-on: ubuntu-latest", "originalFile": "name: Check Constraints\n\n# Pure-library reusable workflow: callable only via `uses:` from a consumer\n# caller workflow. The consumer owns the event trigger (push, pull_request,\n# etc.); this file runs the constraint checker against whatever repo the\n# caller has checked out into $GITHUB_WORKSPACE.\non:\n  workflow_call:\n\njobs:\n  image-digest:\n    name: digest\n    uses: ./.github/workflows/image-digest.yml\n\n  check-constraints:\n    name: check\n    needs: [image-digest]\n    runs-on: ubuntu-latest\n\n    steps:\n      - name: Checkout\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n\n      # No ghcr.io login needed: ghcr.io/clockwork-pilot/autopilot-ws is a public package.\n      # If it's ever made private again, re-add a docker login step with a PAT.\n\n      - name: Cache Docker image\n        id: cache-image\n        uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n        with:\n          path: /tmp/autopilot-ws.tar\n          key: docker-autopilot-ws-${{ needs.image-digest.outputs.digest }}\n\n      - name: Load cached image\n        if: steps.cache-image.outputs.cache-hit == 'true'\n        env:\n          AGENT_IMAGE: ${{ needs.image-digest.outputs.image }}\n        run: |\n          set -e\n          if [ ! -f /tmp/autopilot-ws.tar ]; then\n            echo \"::error::Cache hit reported but /tmp/autopilot-ws.tar not found\"\n            exit 1\n          fi\n          docker load < /tmp/autopilot-ws.tar\n\n      - name: Pull image and save to cache\n        if: steps.cache-image.outputs.cache-hit != 'true'\n        env:\n          AGENT_IMAGE: ${{ needs.image-digest.outputs.image }}\n        run: |\n          set -e\n          docker pull \"$AGENT_IMAGE\"\n          docker save \"$AGENT_IMAGE\" > /tmp/autopilot-ws.tar\n\n      - name: Run constraint checks\n        id: constraints\n        env:\n          GITHUB_WORKSPACE: ${{ github.workspace }}\n          AGENT_IMAGE: ${{ needs.image-digest.outputs.image }}\n        run: |\n          echo \"::group::Constraint Checks\"\n          bash ${{ github.workspace }}/.github/scripts/run-in-docker-no-claude.sh \\\n            \"check_spec_constraints.py || { \\\n              echo '--- Spec checks results ---'; \\\n              cat /workspace/spec-checks.k.md; \\\n              echo '--- testrunner failures ---'; \\\n              grep 'errors out of' /sqlite/testrunner.log 2>/dev/null | grep -v '^0 errors' || echo '(no testrunner.log failures found)'; exit 1; }\" || {\n            echo \"::error::Constraint checks failed\"\n            exit 1\n          }\n          echo \"::endgroup::\"\n", "structuredPatch": [{"oldStart": 9, "oldLines": 11, "newStart": 9, "newLines": 9, "lines": [" ", " jobs:", "   image-digest:", "-    name: digest", "     uses: ./.github/workflows/image-digest.yml", " ", "   check-constraints:", "-    name: check", "     needs: [image-digest]", "     runs-on: ubuntu-latest", " "]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01EnqYtCT4GxhegKTz7LSxST"}}
