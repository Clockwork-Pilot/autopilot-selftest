.image_repo }}:cached\n        CMD: ${{ inputs.command }}\n      run: bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-no-claude.sh\" \"$CMD\"\n", "userModified": false}, "tool_use_id": "toolu_01CKRrouEiNCPsQZKfbWtx5t", "duration_ms": 21}}
