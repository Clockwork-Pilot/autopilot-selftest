{"timestamp": "2026-04-25T21:06:04.554936", "event": "Edit", "data": {"session_id": "c966cf96-0585-4339-a113-e99e77a184d4", "transcript_path": "/home/node/.claude/projects/-workspace/c966cf96-0585-4339-a113-e99e77a184d4.jsonl", "cwd": "/workspace/autopilot", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/scripts/test/run-act-step-checks.sh", "old_string": "FIX_ROOT=\".github/actions/$STEP/fixtures\"", "new_string": "FIX_ROOT=\"${FIXTURES_OVERRIDE:-.github/actions/$STEP/fixtures}\"", "replace_all": false}, "tool_response": {"filePath": "/workspace/autopilot/.github/scripts/test/run-act-step-checks.sh", "oldString": "FIX_ROOT=\".github/actions/$STEP/fixtures\"", "newString": "FIX_ROOT=\"${FIXTURES_OVERRIDE:-.github/actions/$STEP/fixtures}\"", "originalFile": "#!/bin/bash\n# Usage: run-act-step-checks.sh <workflow> <step>\n# Dispatches <step> from <workflow> against every fixture under\n# .github/actions/<step>/fixtures/<case>/ and compares the step's\n# $GITHUB_OUTPUT (parsed into JSON) against the fixture's expected.json.\nset -u\n\nWORKFLOW=\"${1:?workflow required (e.g. coding-agent.yml)}\"\nSTEP=\"${2:?step id required (e.g. parse-issue)}\"\n\nFIX_ROOT=\".github/actions/$STEP/fixtures\"\n[ -d \"$FIX_ROOT\" ] || { echo \"No fixtures dir: $FIX_ROOT\" >&2; exit 1; }\n\nparse_github_output_to_json() {\n  python3 - \"$1\" <<'PY'\nimport json, re, sys\nwith open(sys.argv[1]) as f:\n    lines = f.read().splitlines()\nout, i = {}, 0\nwhile i < len(lines):\n    m = re.match(r'^([^=<]+)<<(.+)$', lines[i])\n    if m:\n        key, delim = m.group(1), m.group(2)\n        i += 1\n        buf = []\n        while i < len(lines) and lines[i] != delim:\n            buf.append(lines[i]); i += 1\n        out[key] = \"\\n\".join(buf)\n    elif '=' in lines[i]:\n        k, v = lines[i].split('=', 1)\n        out[k] = v\n    i += 1\nprint(json.dumps(out, sort_keys=True, indent=2))\nPY\n}\n\nFAIL=0\nfor case_dir in \"$FIX_ROOT\"/*/; do\n  case=$(basename \"$case_dir\")\n  ART=$(mktemp -d)\n  if ! .github/scripts/test/act-step-dispatch.sh \"$WORKFLOW\" \"$STEP\" \\\n         --inputs \"$(cat \"$case_dir/input.json\")\" \\\n         --artifact-server-path \"$ART\" -q; then\n    echo \"FAIL: $STEP/$case (dispatch)\"\n    FAIL=1; continue\n  fi\n  ACTUAL=$(parse_github_output_to_json \"$ART/github_output.txt\")\n  EXPECTED=$(jq -S . \"$case_dir/expected.json\")\n  if diff <(echo \"$EXPECTED\") <(echo \"$ACTUAL\" | jq -S .); then\n    echo \"OK:   $STEP/$case\"\n  else\n    echo \"FAIL: $STEP/$case\"\n    FAIL=1\n  fi\ndone\nexit $FAIL\n", "structuredPatch": [{"oldStart": 8, "oldLines": 7, "newStart": 8, "newLines": 7, "lines": [" WORKFLOW=\"${1:?workflow required (e.g. coding-agent.yml)}\"", " STEP=\"${2:?step id required (e.g. parse-issue)}\"", " ", "-FIX_ROOT=\".github/actions/$STEP/fixtures\"", "+FIX_ROOT=\"${FIXTURES_OVERRIDE:-.github/actions/$STEP/fixtures}\"", " [ -d \"$FIX_ROOT\" ] || { echo \"No fixtures dir: $FIX_ROOT\" >&2; exit 1; }", " ", " parse_github_output_to_json() {"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01VrztwMQuiaM2y6awU6MWUm", "duration_ms": 16}}
