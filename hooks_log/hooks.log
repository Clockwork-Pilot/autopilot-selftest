/tmp/autopilot-setup.sh", "-          # Drop back to the image's default user (image-defined USER directive", "-          # is preserved across FROM, so this reassertion is explicit, not new).", "-          USER node", "-          EOF", "-", "-          echo \"::notice::Building prepared image $TAG from $BASE (script hash: $SCRIPT_HASH)\"", "-          docker build -t \"$TAG\" \"$CTX\"", "-          echo \"image=$TAG\" >> \"$GITHUB_OUTPUT\"", "-", "   run-agent:", "     needs: [validate-runner, fetch-issue, parse-issue, choose-branch, image-digest, prepare-image]", "     runs-on: [self-hosted, \"${{ inputs.runner_label }}\"]"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_013r9iXHzME6SZX5pxqcKEBT", "duration_ms": 19}}
{"timestamp": "2026-04-24T12:27:45.951098", "event": "Write", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/action.yml", "content": "name: Build Agent Image\ndescription: |\n  Build a Dockerfile-based agent/check image with a unified interface across\n  GitHub-hosted and self-hosted runners. Always uses Buildx.\n  - GitHub-hosted runners: layer-level caching via type=gha (GitHub Actions Cache\n    backend), scoped by cache_key_prefix to prevent cross-project interference.\n  - Self-hosted runners: relies on the docker daemon's local layer cache\n    (persistent across runs on the same runner) \u2014 no external cache layer.\n  The output `image` is a local tag both paths produce identically, so callers\n  don't branch on runner type.\n\ninputs:\n  dockerfile:\n    description: Path to the Dockerfile, relative to $GITHUB_WORKSPACE. Must FROM an autopilot-ws-compatible base (USER node at runtime).\n    required: false\n    default: Dockerfile\n  context:\n    description: Build context directory, relative to $GITHUB_WORKSPACE.\n    required: false\n    default: \".\"\n  build_args:\n    description: |\n      Newline-separated KEY=VALUE build args. Forwarded to the builder.\n      Included in the content hash that disambiguates local tags, so a change\n      invalidates the cache even if the Dockerfile text is unchanged.\n    required: false\n    default: \"\"\n  base_image:\n    description: |\n      Base image reference used only for content-hash stability. The action does NOT\n      rewrite the Dockerfile's FROM \u2014 the Dockerfile still decides the base. Set this\n      to the same image you `FROM` so the local tag rotates when upstream is bumped.\n    required: false\n    default: ghcr.io/clockwork-pilot/autopilot-ws:latest\n  tag:\n    description: Local tag base. The computed content hash is appended, producing `<tag>:<prefix>-<hash>`.\n    required: false\n    default: autopilot-ws-custom\n  cache_key_prefix:\n    description: |\n      REQUIRED. Namespace for the GHA buildx cache scope and the local docker tag.\n      Use a project-specific value (e.g. `${{ github.repository }}-agent-img`).\n      Distinct projects MUST use distinct prefixes to avoid cross-project cache\n      interference on shared GHA cache scopes. There is no default: omitting this\n      is a usage error.\n    required: true\n\noutputs:\n  image:\n    description: Fully qualified local tag of the produced image. Ready to `docker run`.\n    value: ${{ steps.finalize.outputs.image }}\n  cache_hit:\n    description: \"true\" if the image was available without rebuilding (local tag present before build); \"false\" otherwise. Does not reflect Buildx layer-level cache reuse, only whether the final tag pre-existed.\n    value: ${{ steps.finalize.outputs.cache_hit }}\n  digest:\n    description: Local image ID (sha256) of the produced image.\n    value: ${{ steps.finalize.outputs.digest }}\n\nruns:\n  using: composite\n  steps:\n    - id: env\n      shell: bash\n      run: |\n        case \"${{ runner.environment }}\" in\n          self-hosted) echo \"is_self_hosted=true\"  >> \"$GITHUB_OUTPUT\" ;;\n          *)           echo \"is_self_hosted=false\" >> \"$GITHUB_OUTPUT\" ;;\n        esac\n\n    - id: base\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n      run: |\n        set -euo pipefail\n        # Hash the manifest for stability. Fall back to pull+inspect if manifest\n        # inspect is unavailable (rare; happens with private registries without\n        # auth in this step).\n        DIGEST=$(docker manifest inspect \"$BASE\" 2>/dev/null | sha256sum | cut -c1-16) || DIGEST=\"\"\n        if [ -z \"$DIGEST\" ]; then\n          docker pull \"$BASE\" >/dev/null\n          DIGEST=$(docker inspect --format='{{.Id}}' \"$BASE\" | sed 's/^sha256://' | cut -c1-16)\n        fi\n        echo \"digest=$DIGEST\" >> \"$GITHUB_OUTPUT\"\n\n    - id: key\n      shell: bash\n      env:\n        DOCKERFILE:  ${{ inputs.dockerfile }}\n        BUILD_ARGS:  ${{ inputs.build_args }}\n        BASE_DIGEST: ${{ steps.base.outputs.digest }}\n        PREFIX:      ${{ inputs.cache_key_prefix }}\n        TAG_BASE:    ${{ inputs.tag }}\n      run: |\n        set -euo pipefail\n        if [ -z \"$PREFIX\" ]; then\n          echo \"::error::cache_key_prefix is required \u2014 see action README\"\n          exit 1\n        fi\n        DF_HASH=$(sha256sum \"$DOCKERFILE\" | cut -c1-16)\n        ARG_HASH=$(printf '%s' \"$BUILD_ARGS\" | sha256sum | cut -c1-16)\n        HASH=\"${DF_HASH}-${BASE_DIGEST}-${ARG_HASH}\"\n        SAFE_PREFIX=$(printf '%s' \"$PREFIX\" | tr '/ ' '__')\n        echo \"hash=$HASH\"                                 >> \"$GITHUB_OUTPUT\"\n        echo \"tag=${TAG_BASE}:${SAFE_PREFIX}-${HASH}\"     >> \"$GITHUB_OUTPUT\"\n        echo \"scope=${SAFE_PREFIX}-buildimg\"              >> \"$GITHUB_OUTPUT\"\n\n    # Fast path: tag already exists locally \u2014 skip build entirely. Important on\n    # self-hosted runners where repeat invocations with identical inputs should\n    # be a no-op, and harmless on ephemeral github-hosted runners (always miss).\n    - id: local\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        if docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          echo \"hit=true\"  >> \"$GITHUB_OUTPUT\"\n        else\n          echo \"hit=false\" >> \"$GITHUB_OUTPUT\"\n        fi\n\n    - if: steps.local.outputs.hit != 'true'\n      uses: docker/setup-buildx-action@c47758b77c9736f4b2ef4073d4d51994fabfe349\n\n    # GitHub-hosted: use GHA cache backend, scoped by cache_key_prefix.\n    # Self-hosted: omit cache-from/cache-to so bu