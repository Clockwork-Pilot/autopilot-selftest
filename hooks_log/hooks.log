_OUTPUT\"\n        fi\n\n    - id: cache\n      if: steps.env.outputs.is_self_hosted != 'true'\n      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n      with:\n        path: /tmp/build-agent-image.tar\n        key:  ${{ steps.key.outputs.cache_key }}\n\n    - id: load\n      if: steps.env.outputs.is_self_hosted != 'true' && steps.cache.outputs.cache-hit == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        set -euo pipefail\n        out=$(docker load < /tmp/build-agent-image.tar)\n        echo \"$out\"\n        if ! docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          src=$(printf '%s\\n' \"$out\" \\\n            | sed -n -e 's/^Loaded image: //p' -e 's/^Loaded image ID: //p' | head -n1)\n          if [ -n \"$src\" ]; then\n            docker tag \"$src\" \"$TAG\"\n          else\n            echo \"::warning::Cache restored but could not resolve loaded image \u2014 will rebuild\"\n            echo \"rebuild=true\" >> \"$GITHUB_OUTPUT\"\n            exit 0\n          fi\n        fi\n        echo \"rebuild=false\" >> \"$GITHUB_OUTPUT\"\n\n    - name: should_build\n      id: should_build\n      shell: bash\n      env:\n        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}\n        LOCAL_HIT:      ${{ steps.local.outputs.hit }}\n        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}\n        REBUILD:        ${{ steps.load.outputs.rebuild }}\n      run: |\n        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then\n          [ \"$LOCAL_HIT\" = \"true\" ] && echo \"yes=false\" >> \"$GITHUB_OUTPUT\" || echo \"yes=true\" >> \"$GITHUB_OUTPUT\"\n        else\n          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then\n            echo \"yes=false\" >> \"$GITHUB_OUTPUT\"\n          else\n            echo \"yes=true\"  >> \"$GITHUB_OUTPUT\"\n          fi\n        fi\n\n    - if: steps.should_build.outputs.yes == 'true'\n      uses: docker/setup-buildx-action@c47758b77c9736f4b2ef4073d4d51994fabfe349\n\n    - id: build\n      if: steps.should_build.outputs.yes == 'true'\n      shell: bash\n      env:\n        DOCKERFILE: ${{ inputs.dockerfile }}\n        CONTEXT:    ${{ inputs.context }}\n        TAG:        ${{ steps.key.outputs.tag }}\n        BUILD_ARGS: ${{ inputs.build_args }}\n      run: |\n        set -euo pipefail\n        ARGS=()\n        while IFS= read -r line; do\n          [ -z \"$line\" ] && continue\n          ARGS+=(--build-arg \"$line\")\n        done <<< \"$BUILD_ARGS\"\n        docker buildx build --load -t \"$TAG\" -f \"$DOCKERFILE\" \"${ARGS[@]}\" \"$CONTEXT\"\n\n    - name: save_tarball\n      if: steps.env.outputs.is_self_hosted != 'true' && steps.should_build.outputs.yes == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: docker save \"$TAG\" > /tmp/build-agent-image.tar\n\n    - id: finalize\n      shell: bash\n      env:\n        TAG:            ${{ steps.key.outputs.tag }}\n        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}\n        LOCAL_HIT:      ${{ steps.local.outputs.hit }}\n        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}\n        REBUILD:        ${{ steps.load.outputs.rebuild }}\n      run: |\n        set -euo pipefail\n        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then\n          HIT=\"$LOCAL_HIT\"\n        else\n          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then HIT=true; else HIT=false; fi\n        fi\n        DIGEST=$(docker inspect --format='{{.Id}}' \"$TAG\")\n        {\n          echo \"image=$TAG\"\n          echo \"cache_hit=$HIT\"\n          echo \"digest=$DIGEST\"\n        } >> \"$GITHUB_OUTPUT\"\n", "structuredPatch": [], "originalFile": null, "userModified": false}, "tool_use_id": "toolu_01RkaUeQqaenhE2XXwgPms6G", "duration_ms": 18}}
{"timestamp": "2026-04-24T12:25:28.972149", "event": "Write", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "content": "# build-agent-image\n\nUnified Docker image builder for autopilot consumers. One composite action, one set of inputs, works the same on **GitHub-hosted** and **self-hosted** runners.\n\n## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.\n- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.\n- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.\n\n## Inputs\n\n| Input | Required | Default | Description |\n|---|---|---|---|\n| `dockerfile` | no | `Dockerfile` | Path to the Dockerfile, relative to `$GITHUB_WORKSPACE`. |\n| `context` | no | `.` | Build context directory. |\n| `build_args` | no | `\"\"` | Newline-separated `KEY=VALUE`. Forwarded to `--build-arg`. |\n| `base_image` | no | `ghcr.io/clockwork-pilot/autopilot-ws:latest` | Used only for cache keying (digest is resolved and hashed). Your Dockerfile's `FROM` line is what actually determines the base. |\n| `tag` | no | `autopilot-ws-custom` | Local tag base. A content hash is appended, producing `<tag>:<prefix>-<hash>`. |\n| `cache_key_prefix` | **yes** | \u2014 | Namespace for the cache entry and local tag. See [Cache key guidelines](#cache-key-guidelines). |\n\n## Outputs\n\n| Output | |\n|---|---|\n| `image` | Fully qualified tag of the produced image (pass this to `docker run`). |\n| `cache_hit` | `true` / `false`. |\n| `digest` | Local image ID (sha256:...). |\n\n## Cache key guidelines\n\n**You must supply `cache_key_prefix`.** There is no default. Picking the wrong value causes either cache collisions (distinct projects eating each other's entries) or cache thrash (same project, different prefix per workflow \u2192 no reuse).\n\nRules of thumb:\n- **Namespace by repo**: use `${{ github.repository }}-<purpose>`, e.g. `octocat/my-app-agent-img`.\n- **Do not include volatile fields** like `github.sha`, `github.run_id`, or the date. The action already hashes Dockerfile content, build args, and base image digest into the key \u2014 anything you add beyond the prefix should be stable for runs that should share a cache.\n- **Distinguish purposes** if one repo builds multiple images: `${{ github.repository }}-check-img` vs `${{ github.repository }}-agent-img`.\n- **Organization-wide images** that several repos should share can use a shared prefix (e.g. `my-org-shared-agent-img`), but only if you trust every workflow writing to it not to poison the cache.\n\nThe full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.\n\n## Usage\n\n### GitHub-hosted runner\n\n```yaml\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### Self-hosted runner\n\nSame call, same inputs \u2014 the action detects `runner.environment == 'self-hosted'` and skips `actions/cache`:\n\n```yaml\njobs:\n  build:\n    runs-on: [self-hosted, my-label]\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### With build args\n\n```yaml\n- uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n  with:\n    dockerfile: Dockerfile.agent\n    cache_key_prefix: ${{ github.repository }}-agent-img\n    build_args: |\n      PYTHON_VERSION=3.12\n      NODE_VERSION=22\n```\n\n## Dockerfile contract\n\nYour Dockerfile must produce an image whose runtime shape matches `autopilot-ws`:\n- `FROM ghcr.io/clockwork-pilot/autopilot-ws:<tag>` (or an ABI-compatible derivative).\n- Final `USER node` (inherited by default; do not override).\n- Tools installed system-wide or on `node`'s PATH.\n\nMinimal example:\n\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\n## Migration from `image_setup_script`\n\n`image_setup_script` (previously accepted by `coding-agent.yml`) has been removed. Move your snippet into a Dockerfile and pass it via this action:\n\nBefore:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  image_setup_script: |\n    apt-get update\n    apt-get install -y ffmpeg\n```\n\nAfter (Dockerfile):\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\nAnd:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  dockerfile:       Dockerfile.agent\n  cache_key_prefix: ${{ github.repository }}-agent-img\n```\n"}, "tool_use_id": "toolu_01TKb9Q4rpxdN53ncyCb4QcS"}}
