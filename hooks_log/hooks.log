    type: string\n        default: \"\"", "newString": "      base_image:\n        description: |\n          Image reference the check runs against. Must be an autopilot-ws-\n          compatible runtime (USER node, tools on PATH). Pulled + tagged\n          when `dockerfile` is unset; used as FROM contract when set.\n        required: false\n        type: string\n        default: ghcr.io/clockwork-pilot/autopilot-ws:latest\n      dockerfile:\n        description: |\n          Optional Dockerfile path. When unset, the check runs against\n          `base_image` as-is. When set, a derived image is built from\n          `base_image` and the check runs against that.\n        required: false\n        type: string\n        default: \"\"", "originalFile": "name: Check Constraints\n\n# Reusable workflow: pairs ensure-docker-image with the dumb check-constraints\n# runner. Consumers get two explicit, visible steps in the run graph:\n# 1) image preparation (with cache hit/miss legible), 2) the constraint check.\n# Consumers that want the flat run-graph form can bypass this shim and wire\n# both actions themselves.\non:\n  workflow_call:\n    inputs:\n      submodules:\n        description: |\n          Forwarded to actions/checkout. Set to \"true\" or \"recursive\" when\n          project.k.json declares specs inside submodule paths; otherwise\n          those spec.k.json files will be missing at constraint-check time.\n        required: false\n        type: string\n        default: \"\"\n      dockerfile:\n        description: |\n          Optional Dockerfile path. When unset, the check runs against\n          ghcr.io/clockwork-pilot/autopilot-ws as-is. When set, a derived\n          image is built and used instead. The Dockerfile must FROM an\n          autopilot-ws-compatible base.\n        required: false\n        type: string\n        default: \"\"\n      build_args:\n        description: Newline-separated KEY=VALUE build args, forwarded to ensure-docker-image.\n        required: false\n        type: string\n        default: \"\"\n      cache_key_prefix:\n        description: |\n          REQUIRED. Namespace for the image cache. See\n          .github/actions/ensure-docker-image/README.md for guidelines.\n          Use e.g. `${{ github.repository }}-check-img`.\n        required: true\n        type: string\n\njobs:\n  check-constraints:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          submodules: ${{ inputs.submodules }}\n\n      - id: image\n        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main\n        with:\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          base_image:       ghcr.io/clockwork-pilot/autopilot-ws:latest\n          tag:              autopilot-check\n          cache_key_prefix: ${{ inputs.cache_key_prefix }}\n\n      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main\n        with:\n          image: ${{ steps.image.outputs.image }}\n", "structuredPatch": [{"oldStart": 16, "oldLines": 12, "newStart": 16, "newLines": 19, "lines": ["         required: false", "         type: string", "         default: \"\"", "+      base_image:", "+        description: |", "+          Image reference the check runs against. Must be an autopilot-ws-", "+          compatible runtime (USER node, tools on PATH). Pulled + tagged", "+          when `dockerfile` is unset; used as FROM contract when set.", "+        required: false", "+        type: string", "+        default: ghcr.io/clockwork-pilot/autopilot-ws:latest", "       dockerfile:", "         description: |", "           Optional Dockerfile path. When unset, the check runs against", "-          ghcr.io/clockwork-pilot/autopilot-ws as-is. When set, a derived", "-          image is built and used instead. The Dockerfile must FROM an", "-          autopilot-ws-compatible base.", "+          `base_image` as-is. When set, a derived image is built from", "+          `base_image` and the check runs against that.", "         required: false", "         type: string", "         default: \"\""]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01AJLwrQJB5pJEAzBRHhAQKQ", "duration_ms": 22}}
