{"timestamp": "2026-04-24T14:59:08.631862", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/workflows/check-constraints.yml", "old_string": "build-agent-image", "new_string": "build-docker-image", "replace_all": true}, "tool_response": {"filePath": "/workspace/autopilot/.github/workflows/check-constraints.yml", "oldString": "build-agent-image", "newString": "build-docker-image", "originalFile": "name: Check Constraints\n\n# Reusable workflow: thin shim over the check-constraints composite action.\n# Exists so consumers that want workflow-level composition (matrix, env,\n# reviewer gates) can still `uses:` this file. Consumers that want the\n# flat run-graph form can bypass this and reference the action directly:\n#   uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@<ref>\non:\n  workflow_call:\n    inputs:\n      submodules:\n        description: |\n          Forwarded to actions/checkout. Set to \"true\" or \"recursive\" when\n          project.k.json declares specs inside submodule paths; otherwise\n          those spec.k.json files will be missing at constraint-check time.\n        required: false\n        type: string\n        default: \"\"\n      dockerfile:\n        description: |\n          Optional path to a Dockerfile to build the check image from. When set,\n          the check runs inside that image instead of ghcr.io/clockwork-pilot/autopilot-ws.\n          Must FROM an autopilot-ws-compatible base.\n        required: false\n        type: string\n        default: \"\"\n      build_args:\n        description: Newline-separated KEY=VALUE build args, forwarded to build-agent-image.\n        required: false\n        type: string\n        default: \"\"\n      cache_key_prefix:\n        description: |\n          Required when `dockerfile` is set. Namespace for the image build cache.\n          See .github/actions/build-agent-image/README.md for guidelines.\n        required: false\n        type: string\n        default: \"\"\n\njobs:\n  check-constraints:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          submodules: ${{ inputs.submodules }}\n      # Reference the action by repo-qualified ref: inside a reusable workflow\n      # `./` resolves against the CALLER's checkout, not the workflow's home\n      # repo, so `uses: ./.github/actions/...` would fail in consumer runs.\n      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main\n        with:\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          cache_key_prefix: ${{ inputs.cache_key_prefix }}\n", "structuredPatch": [{"oldStart": 25, "oldLines": 14, "newStart": 25, "newLines": 14, "lines": ["         type: string", "         default: \"\"", "       build_args:", "-        description: Newline-separated KEY=VALUE build args, forwarded to build-agent-image.", "+        description: Newline-separated KEY=VALUE build args, forwarded to build-docker-image.", "         required: false", "         type: string", "         default: \"\"", "       cache_key_prefix:", "         description: |", "           Required when `dockerfile` is set. Namespace for the image build cache.", "-          See .github/actions/build-agent-image/README.md for guidelines.", "+          See .github/actions/build-docker-image/README.md for guidelines.", "         required: false", "         type: string", "         default: \"\""]}], "userModified": false, "replaceAll": true}, "tool_use_id": "toolu_01XH8twqd5aRb2aBPru8Xzn8", "duration_ms": 15}}
