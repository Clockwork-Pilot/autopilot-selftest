 }\n  prompt:            { required: true,  description: \"Prompt fed to agent.\" }\n  agent_image:       { required: true,  description: \"Local docker tag prepared by ensure-docker-image.\" }\n  timeout_secs:      { required: false, default: \"180\", description: \"Hard timeout for the docker run.\" }\n  extra_docker_args: { required: false, default: \"\",    description: \"Extra args spliced into docker run (forwarded as EXTRA_DOCKER_ARGS).\" }\n  allow_git_commit:  { required: false, default: \"false\", description: \"If 'true', drop the proxy wrapper so the agent can run git commit.\" }\n\noutputs:\n  exit_code: { description: \"Agent process exit code.\", value: \"${{ steps.a.outputs.exit_code }}\" }\n\nruns:\n  using: composite\n  steps:\n    - id: a\n      shell: bash\n      env:\n        MODEL:                    ${{ inputs.model }}\n        PROMPT:                   ${{ inputs.prompt }}\n        AGENT_IMAGE:              ${{ inputs.agent_image }}\n        TIMEOUT_SECS:             ${{ inputs.timeout_secs }}\n        EXTRA_DOCKER_ARGS: ${{ inputs.extra_docker_args }}\n      run: |\n        echo \"::group::Agent Output\"\n        set +e\n        bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-claude.sh\"\n        EXIT_CODE=$?\n        echo \"::endgroup::\"\n        echo \"exit_code=$EXIT_CODE\" >> \"$GITHUB_OUTPUT\"\n        exit \"$EXIT_CODE\"\n", "structuredPatch": [{"oldStart": 23, "oldLines": 10, "newStart": 23, "newLines": 13, "lines": ["         AGENT_IMAGE:              ${{ inputs.agent_image }}", "         TIMEOUT_SECS:             ${{ inputs.timeout_secs }}", "         EXTRA_DOCKER_ARGS: ${{ inputs.extra_docker_args }}", "+        ALLOW_GIT_COMMIT:  ${{ inputs.allow_git_commit }}", "       run: |", "         echo \"::group::Agent Output\"", "         set +e", "-        bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-claude.sh\"", "+        ARGS=()", "+        [ \"$ALLOW_GIT_COMMIT\" = \"true\" ] && ARGS+=(--allow-git-commit)", "+      