ack to pull+inspect if manifest", "+        # inspect is unavailable (rare; happens with private registries without", "+        # auth in this step).", "+        DIGEST=$(docker manifest inspect \"$BASE\" 2>/dev/null | sha256sum | cut -c1-16) || DIGEST=\"\"", "         if [ -z \"$DIGEST\" ]; then", "           docker pull \"$BASE\" >/dev/null", "           DIGEST=$(docker inspect --format='{{.Id}}' \"$BASE\" | sed 's/^sha256://' | cut -c1-16)"]}, {"oldStart": 99, "oldLines": 12, "newStart": 101, "newLines": 14, "lines": ["         ARG_HASH=$(printf '%s' \"$BUILD_ARGS\" | sha256sum | cut -c1-16)", "         HASH=\"${DF_HASH}-${BASE_DIGEST}-${ARG_HASH}\"", "         SAFE_PREFIX=$(printf '%s' \"$PREFIX\" | tr '/ ' '__')", "-        echo \"hash=$HASH\"                         >> \"$GITHUB_OUTPUT\"", "-        echo \"tag=${TAG_BASE}:${SAFE_PREFIX}-${HASH}\" >> \"$GITHUB_OUTPUT\"", "-        echo \"cache_key=${PREFIX}-buildimg-${HASH}\"   >> \"$GITHUB_OUTPUT\"", "+        echo \"hash=$HASH\"                                 >> \"$GITHUB_OUTPUT\"", "+        echo \"tag=${TAG_BASE}:${SAFE_PREFIX}-${HASH}\"     >> \"$GITHUB_OUTPUT\"", "+        echo \"scope=${SAFE_PREFIX}-buildimg\"              >> \"$GITHUB_OUTPUT\"", " ", "+    # Fast path: tag already exists locally \u2014 skip build entirely. Important on", "+    # self-hosted runners where repeat invocations with identical inputs should", "+    # be a no-op, and harmless on ephemeral github-hosted runners (always miss).", "     - id: local", "-      if: steps.env.outputs.is_self_hosted == 'true'", "       shell: bash", "       env:", "         TAG: ${{ steps.key.outputs.tag }}"]}, {"oldStart": 115, "oldLines": 99, "newStart": 119, "newLines": 46, "lines": ["           echo \"hit=false\" >> \"$GITHUB_OUTPUT\"", "         fi", " ", "-    - id: cache", "-      if: steps.env.outputs.is_self_hosted != 'true'", "-      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830", "-      with:", "-        path: /tmp/build-agent-image.tar", "-        key:  ${{ steps.key.outputs.cache_key }}", "-", "-    - id: load", "-      if: steps.env.outputs.is_self_hosted != 'true' && steps.cache.outputs.cache-hit == 'true'", "-      shell: bash", "-      env:", "-        TAG: ${{ steps.key.outputs.tag }}", "-      run: |", "-        set -euo pipefail", "-        out=$(docker load < /tmp/build-agent-image.tar)", "-        echo \"$out\"", "-        if ! docker image inspect \"$TAG\" >/dev/null 2>&1; then", "-          src=$(printf '%s\\n' \"$out\" \\", "-            | sed -n -e 's/^Loaded image: //p' -e 's/^Loaded image ID: //p' | head -n1)", "-          if [ -n \"$src\" ]; then", "-            docker tag \"$src\" \"$TAG\"", "-          else", "-            echo \"::warning::Cache restored but could not resolve loaded image \u2014 will rebuild\"", "-            echo \"rebuild=true\" >> \"$GITHUB_OUTPUT\"", "-            exit 0", "-          fi", "-        fi", "-        echo \"rebuild=false\" >> \"$GITHUB_OUTPUT\"", "-", "-    - name: should_build", "-      id: should_build", "-      shell: bash", "-      env:", "-        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}", "-        LOCAL_HIT:      ${{ steps.local.outputs.hit }}", "-        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}", "-        REBUILD:        ${{ steps.load.outputs.rebuild }}", "-      run: |", "-        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then", "-          [ \"$LOCAL_HIT\" = \"true\" ] && echo \"yes=false\" >> \"$GITHUB_OUTPUT\" || echo \"yes=true\" >> \"$GITHUB_OUTPUT\"", "-        else", "-          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then", "-            echo \"yes=false\" >> \"$GITHUB_OUTPUT\"", "-          else", "-            echo \"yes=true\"  >> \"$GITHUB_OUTPUT\"", "-          fi", "-        fi", "-", "-    - if: steps.should_build.outputs.yes == 'true'", "+    - if: steps.local.outputs.hit != 'true'", "       uses: docker/setup-buildx-action@c47758b77c9736f4b2ef4073d4d51994fabfe349", " ", "-    - id: build", "-      if: steps.should_build.outputs.yes == 'true'", "-      shell: bash", "-      env:", "-        DOCKERFILE: ${{ inputs.dockerfile }}", "-        CONTEXT:    ${{ inputs.context }}", "-        TAG:        ${{ steps.key.outputs.tag }}", "-        BUILD_ARGS: ${{ inputs.build_args }}", "-      run: |", "-        set -euo pipefail", "-        ARGS=()", "-        while IFS= read -r line; do", "-          [ -z \"$line\" ] && continue", "-          ARGS+=(--build-arg \"$line\")", "-        done <<< \"$BUILD_ARGS\"", "-        docker buildx build --load -t \"$TAG\" -f \"$DOCKERFILE\" \"${ARGS[@]}\" \"$CONTEXT\"", "+    # GitHub-hosted: use GHA cache backend, scoped by cache_key_prefix.", "+    # Self-hosted: omit cache-from/cache-to so buildx falls back to the", "+    # daemon's local layer cache (persistent on that runner's disk).", "+    - name: Build (github-hosted, with GHA cache)", "+      if: steps.local.outputs.hit != 'true' && steps.env.outputs.is_self_hosted != 'true'", "+      uses: docker/build-push-action@263435318d21b8e681c14492fe198d362a7d2c10", "+      with:", "+        context:    ${{ inputs.context }}", "+        file:       ${{ inputs.dockerfile }}", "+        build-args: ${{ inputs.build_args }}", "+        tags:       ${{ steps.key.outputs.tag }}", "+        load:       true", "+        push:       false", "+        cache-from: type=gha,scope=${{ steps.key.outputs.scope }}", "+        cache-to:   type=gha,mode=max,scope=${{ steps.key.outputs.scope }}", " ", "-    - name: save_tarball", "-      if: steps.env.outputs.is_self_hosted != 'true' && steps.should_build.outputs.yes == 'true'", "-      shell: bash", "-      env:", "-        TAG: ${{ steps.key.outputs.tag }}", "-      run: docker save \"$TAG\" > /tmp/build-agent-image.tar", "+    - name: Build (self-hosted, docker daemon layer cache)", "+      if: steps.local.outputs.hit != 'true' && steps.env.outputs.is_self_hosted == 'true'", "+      uses: docker/build-push-action@263435318d21b8e681c14492fe198d362a7d2c10", "+      with:", "+        context:    ${{ inputs.context }}", "+        file:       ${{ inputs.dockerfile }}", "+        build-args: ${{ inputs.build_args }}", "+        tags:       ${{ steps.key.outputs.tag }}", "+        load:       true", "+        push:       false", " ", "     - id: finalize", "       shell: bash", "       env:", "-        TAG:            ${{ steps.key.outputs.tag }}", "-        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}", "-        LOCAL_HIT:      ${{ steps.local.outputs.hit }}", "-        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}", "-        REBUILD:        ${{ steps.load.outputs.rebuild }}", "+        TAG:       ${{ steps.key.outputs.tag }}", "+        LOCAL_HIT: ${{ steps.local.outputs.hit }}", "       run: |", "         set -euo pipefail", "-        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then", "-          HIT=\"$LOCAL_HIT\"", "-        else", "-          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then HIT=true; else HIT=false; fi", "-        fi", "         DIGEST=$(docker inspect --format='{{.Id}}' \"$TAG\")", "         {", "           echo \"image=$TAG\"", "-          echo \"cache_hit=$HIT\"", "+          echo \"cache_hit=$LOCAL_HIT\"", "           echo \"digest=$DIGEST\"", "         } >> \"$GITHUB_OUTPUT\""]}], "originalFile": "name: Build Agent Image\ndescription: |\n  Build a Dockerfile-based agent/check image with a unified interface across\n  GitHub-hosted and self-hosted runners. Uses Buildx. On GitHub-hosted runners,\n  caches the built image via actions/cache keyed by (cache_key_prefix, Dockerfile\n  content, base image digest, build args). On self-hosted runners, relies on\n  local docker tags keyed by the same hash \u2014 no tarball round-trips.\n\ninputs:\n  dockerfile:\n    description: Path to the Dockerfile, relative to $GITHUB_WORKSPACE. Must FROM an autopilot-ws-compatible base (USER node at runtime).\n    required: false\n    default: Dockerfile\n  context:\n    description: Build context directory, relative to $GITHUB_WORKSPACE.\n    required: false\n    default: \".\"\n  build_args:\n    description: |\n      Newline-separated KEY=VALUE build args. Forwarded as --build-arg entries to buildx.\n      Included in the cache key, so changing any arg invalidates the cache.\n    required: false\n    default: \"\"\n  base_image:\n    description: |\n      Base image reference used only for cache-key stability. The action does not\n      rewrite the Dockerfile's FROM \u2014 the Dockerfile still decides the base. Set\n      this to the same image you `FROM` so the cache invalidates when the upstream\n      autopilot-ws image is republished.\n    required: false\n    default: ghcr.io/clockwork-pilot/autopilot-ws:latest\n  tag:\n    description: Local tag base. The computed content hash is appended, producing `<tag>:<hash>`.\n    required: false\n    default: autopilot-ws-custom\n  cache_key_prefix:\n    description: |\n      REQUIRED. Namespace for the actions/cache entry and the local docker tag.\n      Use a project-specific value (e.g. `${{ github.repository }}-agent-img`).\n      Distinct projects MUST use distinct prefixes to avoid cache collisions on\n      shared GitHub-hosted cache scopes and to keep self-hosted docker tags\n      disambiguated. There is no default: omitting this is a usage error.\n    required: true\n\noutputs:\n  image:\n    description: Fully qualified local tag of the produced image. Ready to `docker run`.\n    value: ${{ steps.finalize.outputs.image }}\n  cache_hit:\n    description: \"true\" if the image was available without rebuilding (cache restore on GitHub-hosted, local tag present on self-hosted).\n    value: ${{ steps.finalize.outputs.cache_hit }}\n  digest:\n    description: Local image ID (sha256) of the produced image.\n    value: ${{ steps.finalize.outputs.digest }}\n\nruns:\n  using: composite\n  steps:\n    - id: env\n      shell: bash\n      run: |\n        # runner.environment is 'github-hosted' or 'self-hosted'\n        case \"${{ runner.environment }}\" in\n          self-hosted) echo \"is_self_hosted=true\"  >> \"$GITHUB_OUTPUT\" ;;\n          *)           echo \"is_self_hosted=false\" >> \"$GITHUB_OUTPUT\" ;;\n        esac\n\n    - id: base\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n      run: |\n        set -euo pipefail\n        # Resolve the base image's manifest digest for cache-key stability.\n        # Falls back to pull+inspect if manifest inspect is unavailable.\n        DIGEST=$(docker manifest inspect \"$BASE\" 2>/dev/null \\\n          | sha256sum | cut -c1-16) || DIGEST=\"\"\n        if [ -z \"$DIGEST\" ]; then\n          docker pull \"$BASE\" >/dev/null\n          DIGEST=$(docker inspect --format='{{.Id}}' \"$BASE\" | sed 's/^sha256://' | cut -c1-16)\n        fi\n        echo \"digest=$DIGEST\" >> \"$GITHUB_OUTPUT\"\n\n    - id: key\n      shell: bash\n      env:\n        DOCKERFILE:  ${{ inputs.dockerfile }}\n        BUILD_ARGS:  ${{ inputs.build_args }}\n        BASE_DIGEST: ${{ steps.base.outputs.digest }}\n        PREFIX:      ${{ inputs.cache_key_prefix }}\n        TAG_BASE:    ${{ inputs.tag }}\n      run: |\n        set -euo pipefail\n        if [ -z \"$PREFIX\" ]; then\n          echo \"::error::cache_key_prefix is required \u2014 see action README\"\n          exit 1\n        fi\n        DF_HASH=$(sha256sum \"$DOCKERFILE\" | cut -c1-16)\n        ARG_HASH=$(printf '%s' \"$BUILD_ARGS\" | sha256sum | cut -c1-16)\n        HASH=\"${DF_HASH}-${BASE_DIGEST}-${ARG_HASH}\"\n        SAFE_PREFIX=$(printf '%s' \"$PREFIX\" | tr '/ ' '__')\n        echo \"hash=$HASH\"                         >> \"$GITHUB_OUTPUT\"\n        echo \"tag=${TAG_BASE}:${SAFE_PREFIX}-${HASH}\" >> \"$GITHUB_OUTPUT\"\n        echo \"cache_key=${PREFIX}-buildimg-${HASH}\"   >> \"$GITHUB_OUTPUT\"\n\n    - id: local\n      if: steps.env.outputs.is_self_hosted == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        if docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          echo \"hit=true\"  >> \"$GITHUB_OUTPUT\"\n        else\n          echo \"hit=false\" >> \"$GITHUB_OUTPUT\"\n        fi\n\n    - id: cache\n      if: steps.env.outputs.is_self_hosted != 'true'\n      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n      with:\n        path: /tmp/build-agent-image.tar\n        key:  ${{ steps.key.outputs.cache_key }}\n\n    - id: load\n      if: steps.env.outputs.is_self_hosted != 'true' && steps.cache.outputs.cache-hit == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        set -euo pipefail\n        out=$(docker load < /tmp/build-agent-image.tar)\n        echo \"$out\"\n        if ! docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          src=$(printf '%s\\n' \"$out\" \\\n            | sed -n -e 's/^Loaded image: //p' -e 's/^Loaded image ID: //p' | head -n1)\n          if [ -n \"$src\" ]; then\n            docker tag \"$src\" \"$TAG\"\n          else\n            echo \"::warning::Cache restored but could not resolve loaded image \u2014 will rebuild\"\n            echo \"rebuild=true\" >> \"$GITHUB_OUTPUT\"\n            exit 0\n          fi\n        fi\n        echo \"rebuild=false\" >> \"$GITHUB_OUTPUT\"\n\n    - name: should_build\n      id: should_build\n      shell: bash\n      env:\n        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}\n        LOCAL_HIT:      ${{ steps.local.outputs.hit }}\n        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}\n        REBUILD:        ${{ steps.load.outputs.rebuild }}\n      run: |\n        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then\n          [ \"$LOCAL_HIT\" = \"true\" ] && echo \"yes=false\" >> \"$GITHUB_OUTPUT\" || echo \"yes=true\" >> \"$GITHUB_OUTPUT\"\n        else\n          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then\n            echo \"yes=false\" >> \"$GITHUB_OUTPUT\"\n          else\n            echo \"yes=true\"  >> \"$GITHUB_OUTPUT\"\n          fi\n        fi\n\n    - if: steps.should_build.outputs.yes == 'true'\n      uses: docker/setup-buildx-action@c47758b77c9736f4b2ef4073d4d51994fabfe349\n\n    - id: build\n      if: steps.should_build.outputs.yes == 'true'\n      shell: bash\n      env:\n        DOCKERFILE: ${{ inputs.dockerfile }}\n        CONTEXT:    ${{ inputs.context }}\n        TAG:        ${{ steps.key.outputs.tag }}\n        BUILD_ARGS: ${{ inputs.build_args }}\n      run: |\n        set -euo pipefail\n        ARGS=()\n        while IFS= read -r line; do\n          [ -z \"$line\" ] && continue\n          ARGS+=(--build-arg \"$line\")\n        done <<< \"$BUILD_ARGS\"\n        docker buildx build --load -t \"$TAG\" -f \"$DOCKERFILE\" \"${ARGS[@]}\" \"$CONTEXT\"\n\n    - name: save_tarball\n      if: steps.env.outputs.is_self_hosted != 'true' && steps.should_build.outputs.yes == 'true'\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: docker save \"$TAG\" > /tmp/build-agent-image.tar\n\n    - id: finalize\n      shell: bash\n      env:\n        TAG:            ${{ steps.key.outputs.tag }}\n        IS_SELF_HOSTED: ${{ steps.env.outputs.is_self_hosted }}\n        LOCAL_HIT:      ${{ steps.local.outputs.hit }}\n        CACHE_HIT:      ${{ steps.cache.outputs.cache-hit }}\n        REBUILD:        ${{ steps.load.outputs.rebuild }}\n      run: |\n        set -euo pipefail\n        if [ \"$IS_SELF_HOSTED\" = \"true\" ]; then\n          HIT=\"$LOCAL_HIT\"\n        else\n          if [ \"$CACHE_HIT\" = \"true\" ] && [ \"$REBUILD\" != \"true\" ]; then HIT=true; else HIT=false; fi\n        fi\n        DIGEST=$(docker inspect --format='{{.Id}}' \"$TAG\")\n        {\n          echo \"image=$TAG\"\n          echo \"cache_hit=$HIT\"\n          echo \"digest=$DIGEST\"\n        } >> \"$GITHUB_OUTPUT\"\n", "userModified": false}, "tool_use_id": "toolu_01AUnWeaWg64gaBYNX5kagUt", "duration_ms": 17}}
{"timestamp": "2026-04-24T12:27:59.359228", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "old_string": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.\n- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.\n- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "new_string": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx** via `docker/build-push-action`.\n- On **GitHub-hosted** runners: **layer-level** caching via `type=gha` (GitHub Actions Cache backend), scoped by `cache_key_prefix` to prevent cross-project interference. Unchanged layers are reused even when the Dockerfile changes.\n- On **self-hosted** runners: relies on the docker daemon's local layer cache, which is already persistent across runs on the same runner. No external cache layer \u2014 it would just duplicate what the daemon does for free.\n- In both cases: if a local tag with the same content hash already exists, the build step is skipped entirely (fast path).\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "replace_all": false}, "tool_use_id": "toolu_01M7gFHcAgbUnMaYq8BgjXmc"}}
{"timestamp": "2026-04-24T12:27:59.560623", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "old_string": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.\n- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.\n- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "new_string": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx** via `docker/build-push-action`.\n- On **GitHub-hosted** runners: **layer-level** caching via `type=gha` (GitHub Actions Cache backend), scoped by `cache_key_prefix` to prevent cross-project interference. Unchanged layers are reused even when the Dockerfile changes.\n- On **self-hosted** runners: relies on the docker daemon's local layer cache, which is already persistent across runs on the same runner. No external cache layer \u2014 it would just duplicate what the daemon does for free.\n- In both cases: if a local tag with the same content hash already exists, the build step is skipped entirely (fast path).\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "replace_all": false}, "tool_response": {"filePath": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "oldString": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.\n- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.\n- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "newString": "## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx** via `docker/build-push-action`.\n- On **GitHub-hosted** runners: **layer-level** caching via `type=gha` (GitHub Actions Cache backend), scoped by `cache_key_prefix` to prevent cross-project interference. Unchanged layers are reused even when the Dockerfile changes.\n- On **self-hosted** runners: relies on the docker daemon's local layer cache, which is already persistent across runs on the same runner. No external cache layer \u2014 it would just duplicate what the daemon does for free.\n- In both cases: if a local tag with the same content hash already exists, the build step is skipped entirely (fast path).\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", "originalFile": "# build-agent-image\n\nUnified Docker image builder for autopilot consumers. One composite action, one set of inputs, works the same on **GitHub-hosted** and **self-hosted** runners.\n\n## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.\n- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.\n- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.\n\n## Inputs\n\n| Input | Required | Default | Description |\n|---|---|---|---|\n| `dockerfile` | no | `Dockerfile` | Path to the Dockerfile, relative to `$GITHUB_WORKSPACE`. |\n| `context` | no | `.` | Build context directory. |\n| `build_args` | no | `\"\"` | Newline-separated `KEY=VALUE`. Forwarded to `--build-arg`. |\n| `base_image` | no | `ghcr.io/clockwork-pilot/autopilot-ws:latest` | Used only for cache keying (digest is resolved and hashed). Your Dockerfile's `FROM` line is what actually determines the base. |\n| `tag` | no | `autopilot-ws-custom` | Local tag base. A content hash is appended, producing `<tag>:<prefix>-<hash>`. |\n| `cache_key_prefix` | **yes** | \u2014 | Namespace for the cache entry and local tag. See [Cache key guidelines](#cache-key-guidelines). |\n\n## Outputs\n\n| Output | |\n|---|---|\n| `image` | Fully qualified tag of the produced image (pass this to `docker run`). |\n| `cache_hit` | `true` / `false`. |\n| `digest` | Local image ID (sha256:...). |\n\n## Cache key guidelines\n\n**You must supply `cache_key_prefix`.** There is no default. Picking the wrong value causes either cache collisions (distinct projects eating each other's entries) or cache thrash (same project, different prefix per workflow \u2192 no reuse).\n\nRules of thumb:\n- **Namespace by repo**: use `${{ github.repository }}-<purpose>`, e.g. `octocat/my-app-agent-img`.\n- **Do not include volatile fields** like `github.sha`, `github.run_id`, or the date. The action already hashes Dockerfile content, build args, and base image digest into the key \u2014 anything you add beyond the prefix should be stable for runs that should share a cache.\n- **Distinguish purposes** if one repo builds multiple images: `${{ github.repository }}-check-img` vs `${{ github.repository }}-agent-img`.\n- **Organization-wide images** that several repos should share can use a shared prefix (e.g. `my-org-shared-agent-img`), but only if you trust every workflow writing to it not to poison the cache.\n\nThe full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.\n\n## Usage\n\n### GitHub-hosted runner\n\n```yaml\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### Self-hosted runner\n\nSame call, same inputs \u2014 the action detects `runner.environment == 'self-hosted'` and skips `actions/cache`:\n\n```yaml\njobs:\n  build:\n    runs-on: [self-hosted, my-label]\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### With build args\n\n```yaml\n- uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n  with:\n    dockerfile: Dockerfile.agent\n    cache_key_prefix: ${{ github.repository }}-agent-img\n    build_args: |\n      PYTHON_VERSION=3.12\n      NODE_VERSION=22\n```\n\n## Dockerfile contract\n\nYour Dockerfile must produce an image whose runtime shape matches `autopilot-ws`:\n- `FROM ghcr.io/clockwork-pilot/autopilot-ws:<tag>` (or an ABI-compatible derivative).\n- Final `USER node` (inherited by default; do not override).\n- Tools installed system-wide or on `node`'s PATH.\n\nMinimal example:\n\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\n## Migration from `image_setup_script`\n\n`image_setup_script` (previously accepted by `coding-agent.yml`) has been removed. Move your snippet into a Dockerfile and pass it via this action:\n\nBefore:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  image_setup_script: |\n    apt-get update\n    apt-get install -y ffmpeg\n```\n\nAfter (Dockerfile):\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\nAnd:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  dockerfile:       Dockerfile.agent\n  cache_key_prefix: ${{ github.repository }}-agent-img\n```\n", "structuredPatch": [{"oldStart": 4, "oldLines": 9, "newStart": 4, "newLines": 10, "lines": [" ", " ## What it does", " ", "-- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx**.", "-- On **GitHub-hosted** runners: caches the built image tarball via `actions/cache` under a user-namespaced key. Misses rebuild; hits `docker load`.", "-- On **self-hosted** runners: skips `actions/cache` entirely. The local docker daemon already caches layers; the action just checks whether a tag with the computed content hash is present and rebuilds if not.", "+- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx** via `docker/build-push-action`.", "+- On **GitHub-hosted** runners: **layer-level** caching via `type=gha` (GitHub Actions Cache backend), scoped by `cache_key_prefix` to prevent cross-project interference. Unchanged layers are reused even when the Dockerfile changes.", "+- On **self-hosted** runners: relies on the docker daemon's local layer cache, which is already persistent across runs on the same runner. No external cache layer \u2014 it would just duplicate what the daemon does for free.", "+- In both cases: if a local tag with the same content hash already exists, the build step is skipped entirely (fast path).", " - Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.", " ", " ## Inputs"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01M7gFHcAgbUnMaYq8BgjXmc", "duration_ms": 17}}
{"timestamp": "2026-04-24T12:28:11.573240", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "old_string": "The full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.", "new_string": "Two things use the prefix:\n1. **GHA cache scope** (`type=gha,scope=<prefix>-buildimg`) \u2014 isolates Buildx's layer cache per project. Buildx manages layer-level reuse within that scope; you don't need to invalidate manually.\n2. **Local docker tag** (`<tag>:<prefix>-<content-hash>`) \u2014 disambiguates images when the same self-hosted runner serves multiple projects. The content hash is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest.\n\nSame inputs \u2192 same tag \u2192 skip-build fast path. Any input changes \u2192 new tag \u2192 rebuild (layer cache still reusable within scope).", "replace_all": false}, "tool_use_id": "toolu_0167526X1HW9HmzVhrMzhvdv"}}
{"timestamp": "2026-04-24T12:28:11.778114", "event": "Edit", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PostToolUse", "tool_name": "Edit", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "old_string": "The full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.", "new_string": "Two things use the prefix:\n1. **GHA cache scope** (`type=gha,scope=<prefix>-buildimg`) \u2014 isolates Buildx's layer cache per project. Buildx manages layer-level reuse within that scope; you don't need to invalidate manually.\n2. **Local docker tag** (`<tag>:<prefix>-<content-hash>`) \u2014 disambiguates images when the same self-hosted runner serves multiple projects. The content hash is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest.\n\nSame inputs \u2192 same tag \u2192 skip-build fast path. Any input changes \u2192 new tag \u2192 rebuild (layer cache still reusable within scope).", "replace_all": false}, "tool_response": {"filePath": "/workspace/autopilot/.github/actions/build-agent-image/README.md", "oldString": "The full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.", "newString": "Two things use the prefix:\n1. **GHA cache scope** (`type=gha,scope=<prefix>-buildimg`) \u2014 isolates Buildx's layer cache per project. Buildx manages layer-level reuse within that scope; you don't need to invalidate manually.\n2. **Local docker tag** (`<tag>:<prefix>-<content-hash>`) \u2014 disambiguates images when the same self-hosted runner serves multiple projects. The content hash is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest.\n\nSame inputs \u2192 same tag \u2192 skip-build fast path. Any input changes \u2192 new tag \u2192 rebuild (layer cache still reusable within scope).", "originalFile": "# build-agent-image\n\nUnified Docker image builder for autopilot consumers. One composite action, one set of inputs, works the same on **GitHub-hosted** and **self-hosted** runners.\n\n## What it does\n\n- Builds a user-supplied Dockerfile (expected to `FROM` an `autopilot-ws`-compatible base) with **Buildx** via `docker/build-push-action`.\n- On **GitHub-hosted** runners: **layer-level** caching via `type=gha` (GitHub Actions Cache backend), scoped by `cache_key_prefix` to prevent cross-project interference. Unchanged layers are reused even when the Dockerfile changes.\n- On **self-hosted** runners: relies on the docker daemon's local layer cache, which is already persistent across runs on the same runner. No external cache layer \u2014 it would just duplicate what the daemon does for free.\n- In both cases: if a local tag with the same content hash already exists, the build step is skipped entirely (fast path).\n- Produces **one local tag** the caller passes to `docker run` / downstream jobs \u2014 identical shape regardless of runner type.\n\n## Inputs\n\n| Input | Required | Default | Description |\n|---|---|---|---|\n| `dockerfile` | no | `Dockerfile` | Path to the Dockerfile, relative to `$GITHUB_WORKSPACE`. |\n| `context` | no | `.` | Build context directory. |\n| `build_args` | no | `\"\"` | Newline-separated `KEY=VALUE`. Forwarded to `--build-arg`. |\n| `base_image` | no | `ghcr.io/clockwork-pilot/autopilot-ws:latest` | Used only for cache keying (digest is resolved and hashed). Your Dockerfile's `FROM` line is what actually determines the base. |\n| `tag` | no | `autopilot-ws-custom` | Local tag base. A content hash is appended, producing `<tag>:<prefix>-<hash>`. |\n| `cache_key_prefix` | **yes** | \u2014 | Namespace for the cache entry and local tag. See [Cache key guidelines](#cache-key-guidelines). |\n\n## Outputs\n\n| Output | |\n|---|---|\n| `image` | Fully qualified tag of the produced image (pass this to `docker run`). |\n| `cache_hit` | `true` / `false`. |\n| `digest` | Local image ID (sha256:...). |\n\n## Cache key guidelines\n\n**You must supply `cache_key_prefix`.** There is no default. Picking the wrong value causes either cache collisions (distinct projects eating each other's entries) or cache thrash (same project, different prefix per workflow \u2192 no reuse).\n\nRules of thumb:\n- **Namespace by repo**: use `${{ github.repository }}-<purpose>`, e.g. `octocat/my-app-agent-img`.\n- **Do not include volatile fields** like `github.sha`, `github.run_id`, or the date. The action already hashes Dockerfile content, build args, and base image digest into the key \u2014 anything you add beyond the prefix should be stable for runs that should share a cache.\n- **Distinguish purposes** if one repo builds multiple images: `${{ github.repository }}-check-img` vs `${{ github.repository }}-agent-img`.\n- **Organization-wide images** that several repos should share can use a shared prefix (e.g. `my-org-shared-agent-img`), but only if you trust every workflow writing to it not to poison the cache.\n\nThe full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.\n\n## Usage\n\n### GitHub-hosted runner\n\n```yaml\njobs:\n  build:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### Self-hosted runner\n\nSame call, same inputs \u2014 the action detects `runner.environment == 'self-hosted'` and skips `actions/cache`:\n\n```yaml\njobs:\n  build:\n    runs-on: [self-hosted, my-label]\n    steps:\n      - uses: actions/checkout@v4\n      - id: img\n        uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n        with:\n          dockerfile: Dockerfile.agent\n          cache_key_prefix: ${{ github.repository }}-agent-img\n      - run: docker run --rm ${{ steps.img.outputs.image }} my-entrypoint\n```\n\n### With build args\n\n```yaml\n- uses: Clockwork-Pilot/autopilot/.github/actions/build-agent-image@main\n  with:\n    dockerfile: Dockerfile.agent\n    cache_key_prefix: ${{ github.repository }}-agent-img\n    build_args: |\n      PYTHON_VERSION=3.12\n      NODE_VERSION=22\n```\n\n## Dockerfile contract\n\nYour Dockerfile must produce an image whose runtime shape matches `autopilot-ws`:\n- `FROM ghcr.io/clockwork-pilot/autopilot-ws:<tag>` (or an ABI-compatible derivative).\n- Final `USER node` (inherited by default; do not override).\n- Tools installed system-wide or on `node`'s PATH.\n\nMinimal example:\n\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\n## Migration from `image_setup_script`\n\n`image_setup_script` (previously accepted by `coding-agent.yml`) has been removed. Move your snippet into a Dockerfile and pass it via this action:\n\nBefore:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  image_setup_script: |\n    apt-get update\n    apt-get install -y ffmpeg\n```\n\nAfter (Dockerfile):\n```dockerfile\nFROM ghcr.io/clockwork-pilot/autopilot-ws:latest\nUSER 0\nRUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \\\n    && rm -rf /var/lib/apt/lists/*\nUSER node\n```\n\nAnd:\n```yaml\nuses: Clockwork-Pilot/autopilot/.github/workflows/coding-agent.yml@main\nwith:\n  dockerfile:       Dockerfile.agent\n  cache_key_prefix: ${{ github.repository }}-agent-img\n```\n", "structuredPatch": [{"oldStart": 39, "oldLines": 8, "newStart": 39, "newLines": 12, "lines": [" - **Distinguish purposes** if one repo builds multiple images: `${{ github.repository }}-check-img` vs `${{ github.repository }}-agent-img`.", " - **Organization-wide images** that several repos should share can use a shared prefix (e.g. `my-org-shared-agent-img`), but only if you trust every workflow writing to it not to poison the cache.", " ", "-The full cache key is `<prefix>-buildimg-<content-hash>`, where `<content-hash>` is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest. Same inputs \u2192 same key \u2192 cache reuse. Any input changes \u2192 new key \u2192 rebuild.", "+Two things use the prefix:", "+1. **GHA cache scope** (`type=gha,scope=<prefix>-buildimg`) \u2014 isolates Buildx's layer cache per project. Buildx manages layer-level reuse within that scope; you don't need to invalidate manually.", "+2. **Local docker tag** (`<tag>:<prefix>-<content-hash>`) \u2014 disambiguates images when the same self-hosted runner serves multiple projects. The content hash is a deterministic function of the Dockerfile, `build_args`, and `base_image` digest.", " ", "+Same inputs \u2192 same tag \u2192 skip-build fast path. Any input changes \u2192 new tag \u2192 rebuild (layer cache still reusable within scope).", "+", " ## Usage", " ", " ### GitHub-hosted runner"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_0167526X1HW9HmzVhrMzhvdv", "duration_ms": 10}}
