{"timestamp": "2026-04-23T14:01:11.362653", "event": "Write", "data": {"session_id": "52dd771c-b9eb-4144-8085-1b2d99eb1964", "transcript_path": "/home/node/.claude/projects/-workspace/52dd771c-b9eb-4144-8085-1b2d99eb1964.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/parse-digest/script.sh", "content": "#!/usr/bin/env bash\n# Parses a docker manifest JSON and emits digest/image to $GITHUB_OUTPUT.\n# Required env: MANIFEST_JSON, IMAGE_REPO, GITHUB_OUTPUT.\nset -euo pipefail\n: \"${MANIFEST_JSON:?MANIFEST_JSON is required}\"\n: \"${IMAGE_REPO:?IMAGE_REPO is required}\"\n: \"${GITHUB_OUTPUT:?GITHUB_OUTPUT is required}\"\n\necho \"$MANIFEST_JSON\" | python3 -c '\nimport json, os, sys\nm = json.load(sys.stdin)\nif m.get(\"manifests\"):\n    digest = m[\"manifests\"][0].get(\"digest\", \"\")\nelif \"config\" in m:\n    digest = m[\"config\"].get(\"digest\", \"\")\nelse:\n    print(\"ERROR: no digest found in manifest\", file=sys.stderr); sys.exit(1)\nif not digest:\n    print(\"ERROR: digest is empty\", file=sys.stderr); sys.exit(1)\nimage_repo = os.environ[\"IMAGE_REPO\"]\nwith open(os.environ[\"GITHUB_OUTPUT\"], \"a\") as f:\n    f.write(f\"digest={digest}\\n\")\n    f.write(f\"image={image_repo}@{digest}\\n\")\n'\n"}, "tool_use_id": "toolu_017gSonAqy9gVqVS3bG2GXMG"}}
