elative to $GITHUB_WORKSPACE. Only used when `dockerfile` is set.\n    required: false\n    default: \".\"\n  build_args:\n    description: Newline-separated KEY=VALUE build args, forwarded to the builder.\n    required: false\n    default: \"\"\n  base_image:\n    description: Image reference to pull and tag locally, and the FROM contract for any Dockerfile.\n    required: true\n  tag_prefix:\n    description: REQUIRED. Project namespace. See ensure-image-hosted / ensure-image-local for details.\n    required: true\n\noutputs:\n  image:\n    description: Fully qualified local tag of the produced image.\n    value: ${{ steps.hosted.outputs.image || steps.local.outputs.image }}\n  cache_hit:\n    description: '\"true\" if the local tag pre-existed and neither build nor pull ran.'\n    value: ${{ steps.hosted.outputs.cache_hit || steps.local.outputs.cache_hit }}\n  digest:\n    description: Local image ID (sha256) of the produced image.\n    value: ${{ steps.hosted.outputs.digest || steps.local.outputs.digest }}\n\nruns:\n  using: composite\n  steps:\n    - id: hosted\n      if: runner.environment != 'self-hosted'\n      uses: Clockwork-Pilot/autopilot/.github/actions/ensure-image-hosted@main\n      with:\n        dockerfile: ${{ inputs.dockerfile }}\n        context:    ${{ inputs.context }}\n        build_args: ${{ inputs.build_args }}\n        base_image: ${{ inputs.base_image }}\n        tag_prefix: ${{ inputs.tag_prefix }}\n\n    - id: local\n      if: runner.environment == 'self-hosted'\n      uses: Clockwork-Pilot/autopilot/.github/actions/ensure-image-local@main\n      with:\n        dockerfile: ${{ inputs.dockerfile }}\n        context:    ${{ inputs.context }}\n        build_args: ${{ inputs.build_args }}\n        base_image: ${{ inputs.base_image }}\n        tag_prefix: ${{ inputs.tag_prefix }}\n", "structuredPatch": [], "originalFile": null, "userModified": false}, "tool_use_id": "toolu_015RyghGbZxp44jFaq7HZocw", "duration_ms": 17}}
{"timestamp": "2026-04-26T12:30:45.194876", "event": "Stop", "status": "allowed", "data": {"session_id": "7a1f01a6-1a9b-4c52-a425-29713aa330f7", "transcript_path": "/home/node/.claude/projects/-workspace/7a1f01a6-1a9b-4c52-a425-29713aa330f7.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "Stop", "stop_hook_active": false, "last_assistant_message": "All constraints pass. Summary of the split:\n\n- `actions/ensure-image-hosted/action.yml` \u2014 GitHub-hosted runner: GHA cache for both pull (actions/cache + tarball) and build (buildx `type=gha`). 7 steps.\n- `actions/ensure-image-local/action.yml` \u2014 self-hosted runner: trusts the docker daemon's layer cache, no external cache plumbing. 5 steps.\n- `actions/ensure-docker-image/action.yml` \u2014 now a 2-step dispatcher that picks one of the leaves by `runner.environment`. Inputs/outputs preserved for backward compatibility.\n\nPublic surface unchanged: `workflows/ensure-docker-image.yml` and `check-constraints.yml`'s `uses:` line both still resolve, and `ensure_docker_image_uses_tag_prefix_not_tag` (the locked constraint) keeps passing.\n\nThe README still describes the unified caching story \u2014 want me to update `actions/ensure-docker-image/README.md` to point at the leaf action READMEs (and add minimal READMEs for the two leaves)?"}, "vars": {"PROJECT_ROOT": "/workspace", "PLUGIN_ROOT": "/plugin", "WORKSPACE_ROOT": "/workspace"}}
