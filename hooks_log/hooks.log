       required: false\n        type: string\n        default: cached-image\n    outputs:\n      docker_image:\n        description: Fully qualified local tag of the produced image. Pass to coding-agent.yml or another consumer.\n        value: ${{ jobs.ensure.outputs.image }}\n\njobs:\n  ensure:\n    runs-on: [self-hosted, \"${{ inputs.runner_label }}\"]\n    outputs:\n      image: ${{ steps.e.outputs.image }}\n    steps:\n      - if: inputs.dockerfile != ''\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n\n      - id: e\n        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main\n        with:\n          base_image:       ${{ inputs.base_image }}\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          tag:              ${{ inputs.tag }}\n          cache_key_prefix: ${{ inputs.cache_key_prefix }}\n"}, "tool_response": {"type": "create", "filePath": "/workspace/autopilot/.github/workflows/ensure-docker-image.yml", "content": "name: Ensure Docker Image\n\n# Reusable workflow: thin wrapper around the ensure-docker-image composite\n# action, so callers can hoist image preparation into its own job when they\n# want it visible at the caller level (matrix, approval gate, handoff to\n# another reusable workflow).\n#\n# Runs on [self-hosted, <runner_label>] so the produced local docker tag is\n# on the same daemon that downstream agent/check jobs will use. If the caller\n# passes `docker_image` downstream, both jobs MUST land on the same runner\n# (local tags don't cross docker daemons).\n\non:\n  workflow_call:\n    inputs:\n      runner_label:\n        description: GitHub username (matches self-hosted runner label).\n        required: true\n        type: string\n      base_image:\n        description: Base image ref. Pulled and tagged locally; also used as the FROM contract if a dockerfile is supplied.\n        required: true\n        type: string\n      dockerfile:\n        description: Optional path to a Dockerfile to build on top of base_image. Leave empty to only pull+tag base_image.\n        required: false\n        type: string\n        default: \"\"\n      build_args:\n        description: Newline-separated KEY=VALUE, forwarded to the builder.\n        required: false\n        type: string\n        default: \"\"\n      cache_key_prefix:\n        description: REQUIRED. See .github/actions/ensure-docker-image/README.md.\n        required: true\n        type: string\n      tag:\n        description: Local tag base (a content hash is appended).\n        required: false\n        type: string\n        default: cached-image\n    outputs:\n      docker_image:\n        description: Fully qualified local tag of the produced image. Pass to coding-agent.yml or another consumer.\n        value: ${{ jobs.ensure.outputs.image }}\n\njobs:\n  ensure:\n    runs-on: [self-hosted, \"${{ inputs.runner_label }}\"]\n    outputs:\n      image: ${{ steps.e.outputs.image }}\n    steps:\n      - if: inputs.dockerfile != ''\n        uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n\n      - id: e\n        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main\n        with:\n          base_image:       ${{ inputs.base_image }}\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          tag:              ${{ inputs.tag }}\n          cache_key_prefix: ${{ inputs.cache_key_prefix }}\n", "structuredPatch": [], "originalFile": null, "userModified": false}, "tool_use_id": "toolu_01CJzQoHjzzX5RtsbPv1MWU9", "duration_ms": 20}}
