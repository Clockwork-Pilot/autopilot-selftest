{"timestamp": "2026-04-26T02:08:03.719921", "event": "Write", "data": {"session_id": "f3f66d06-7f92-4db6-97f8-5f5513c17dd2", "transcript_path": "/home/node/.claude/projects/-workspace/f3f66d06-7f92-4db6-97f8-5f5513c17dd2.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/check-constraints/action.yml", "content": "name: check-constraints\ndescription: Run check_spec_constraints.py inside a prepared docker image. Image preparation (pull or build) is the caller's responsibility \u2014 use ensure-docker-image upstream of this step.\n\ninputs:\n  image:\n    description: Local docker image ref produced by ensure-docker-image (or equivalent). Must be an autopilot-ws-compatible runtime.\n    required: true\n  command:\n    description: Command to run inside the image. Default runs the constraint checker.\n    required: false\n    default: check_spec_constraints.py\n  extra_docker_args:\n    description: Extra args spliced into `docker run` (forwarded as EXTRA_DOCKER_ARGS).\n    required: false\n    default: \"\"\n\noutputs:\n  exit_code:\n    description: Exit code of the in-container command.\n    value: ${{ steps.run.outputs.exit_code }}\n  body:\n    description: Stdout+stderr of the in-container command (the constraint report).\n    value: ${{ steps.run.outputs.body }}\n\nruns:\n  using: composite\n  steps:\n    - name: Run check inside image\n      id: run\n      shell: bash\n      env:\n        AGENT_IMAGE: ${{ inputs.image }}\n        CMD: ${{ inputs.command }}\n        EXTRA_DOCKER_ARGS: ${{ inputs.extra_docker_args }}\n      run: |\n        set +e\n        OUT=$(mktemp)\n        bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-no-agent.sh\" \"$CMD\" > \"$OUT\" 2>&1\n        EXIT_CODE=$?\n        cat \"$OUT\"\n        echo \"exit_code=$EXIT_CODE\" >> \"$GITHUB_OUTPUT\"\n        {\n          echo \"body<<EOF_CONSTRAINTS_BODY\"\n          cat \"$OUT\"\n          echo \"EOF_CONSTRAINTS_BODY\"\n        } >> \"$GITHUB_OUTPUT\"\n        exit \"$EXIT_CODE\"\n"}, "tool_use_id": "toolu_01CNfCumtfcGXZu8X676PRMJ"}}
