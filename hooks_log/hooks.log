sys.stdin)))')\n          echo \"manifest_json=$compact\" >> \"$GITHUB_OUTPUT\"\n\n  # Verified by: step_output_checks/parse_digest_via_action\n  parse-digest:\n    name: parse-digest\n    needs: [fetch-manifest]\n    runs-on: ubuntu-latest\n    # env: retained so act-step-dispatch.sh can resolve fixture inputs against\n    # the expression keys here. Values are forwarded to the composite action\n    # via `with:` below.\n    env:\n      MANIFEST_JSON: ${{ needs.fetch-manifest.outputs.manifest_json }}\n      IMAGE_REPO:    ${{ inputs.image_repo }}\n    outputs:\n      digest: ${{ steps.p.outputs.digest }}\n      image:  ${{ steps.p.outputs.image }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n      - id: p\n        uses: ./.github/actions/parse-digest\n        with:\n          manifest_json: ${{ needs.fetch-manifest.outputs.manifest_json }}\n          image_repo:    ${{ inputs.image_repo }}\n", "structuredPatch": [{"oldStart": 53, "oldLines": 7, "newStart": 53, "newLines": 7, "lines": ["     steps:", "       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd", "       - id: p", "-        uses: ./.github/actions/parse-digest", "+        uses: Clockwork-Pilot/autopilot/.github/actions/parse-digest@main", "         with:", "           manifest_json: ${{ needs.fetch-manifest.outputs.manifest_json }}", "           image_repo:    ${{ inputs.image_repo }}"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01KoxcfRdd9G7uqvHkGnsJW4", "duration_ms": 17}}
