 IMAGE_REPO: ${{ inputs.image_repo }}", "-      run: |", "-        docker pull \"$AGENT_IMAGE\"", "-        # Tag before save: docker save on a digest-only reference loses the", "-        # name on load, leaving a dangling image ID that docker run can't", "-        # resolve by @sha256. Tagging gives the tar a stable local ref.", "-        docker tag \"$AGENT_IMAGE\" \"$IMAGE_REPO:cached\"", "-        docker save \"$IMAGE_REPO:cached\" > /tmp/autopilot-ws.tar", "-", "-    # --- Run --------------------------------------------------------------", "-    - id: run", "-      shell: bash", "-      env:", "-        AGENT_IMAGE: ${{ inputs.image_repo }}:cached", "+        AGENT_IMAGE: ghcr.io/clockwork-pilot/autopilot-ws:cached", "         CMD: ${{ inputs.command }}", "       run: bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-no-claude.sh\" \"$CMD\""]}], "originalFile": "name: check-constraints\ndescription: Run check_spec_constraints.py against the caller's checked-out workspace. Uses the autopilot-ws image by default, or a user-supplied Dockerfile via build-docker-image.\n\ninputs:\n  image_repo:\n    description: Registry repo for the constraint-check toolchain image. Ignored when `dockerfile` is set.\n    required: false\n    default: ghcr.io/clockwork-pilot/autopilot-ws\n  command:\n    description: Command to run inside the image. Default runs the constraint checker.\n    required: false\n    default: check_spec_constraints.py\n  dockerfile:\n    description: |\n      Optional path to a Dockerfile (relative to the caller's $GITHUB_WORKSPACE). When set,\n      this action builds the image via build-docker-image instead of pulling image_repo.\n    required: false\n    default: \"\"\n  build_args:\n    description: Newline-separated KEY=VALUE build args. Only used when `dockerfile` is set.\n    required: false\n    default: \"\"\n  cache_key_prefix:\n    description: |\n      Required when `dockerfile` is set. Namespace for the build cache.\n      See build-docker-image/README.md \u2192 Cache key guidelines.\n    required: false\n    default: \"\"\n\nruns:\n  using: composite\n  steps:\n    # --- Custom Dockerfile path -------------------------------------------\n    - id: custom\n      if: inputs.dockerfile != ''\n      uses: Clockwork-Pilot/autopilot/.github/actions/build-docker-image@main\n      with:\n        dockerfile:       ${{ inputs.dockerfile }}\n        build_args:       ${{ inputs.build_args }}\n        base_image:       ${{ inputs.image_repo }}:latest\n        tag:              autopilot-check\n        cache_key_prefix: ${{ inputs.cache_key_prefix }}\n\n    - id: tag-custom\n      if: inputs.dockerfile != ''\n      shell: bash\n      env:\n        BUILT:      ${{ steps.custom.outputs.image }}\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        # run-in-docker-no-claude.sh expects <image_repo>:cached \u2014 retag.\n        docker tag \"$BUILT\" \"$IMAGE_REPO:cached\"\n\n    # --- Default (pull+cache autopilot-ws) path ---------------------------\n    - id: fetch\n      if: inputs.dockerfile == ''\n      shell: bash\n      env:\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        set -e\n        manifest=$(docker manifest inspect \"$IMAGE_REPO:latest\")\n        {\n          echo \"manifest_json<<EOF_MANIFEST\"\n          echo \"$manifest\"\n          echo \"EOF_MANIFEST\"\n        } >> \"$GITHUB_OUTPUT\"\n\n    - id: digest\n      if: inputs.dockerfile == ''\n      # Repo-qualified: inside a composite action invoked cross-repo,\n      # `./` resolves against the caller's checkout, not this repo.\n      uses: Clockwork-Pilot/autopilot/.github/actions/parse-digest@main\n      with:\n        manifest_json: ${{ steps.fetch.outputs.manifest_json }}\n        image_repo:    ${{ inputs.image_repo }}\n\n    - id: cache\n      if: inputs.dockerfile == ''\n      uses: actions/cache@0057852bfaa89a56745cba8c7296529d2fc39830\n      with:\n        path: /tmp/autopilot-ws.tar\n        key: docker-autopilot-ws-${{ steps.digest.outputs.image }}\n\n    - id: load\n      shell: bash\n      if: inputs.dockerfile == '' && steps.cache.outputs.cache-hit == 'true'\n      env:\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        out=$(docker load < /tmp/autopilot-ws.tar)\n        echo \"$out\"\n        # Re-tag to :cached regardless of whether the tar carried a tag\n        # (newer saves) or only an image ID (older saves from a digest-only\n        # ref). Without this, a dangling load leaves docker run unable to\n        # resolve the image locally and it falls back to pulling.\n        src=$(printf '%s\\n' \"$out\" | sed -n -e 's/^Loaded image: //p' -e 's/^Loaded image ID: //p' | head -n1)\n        if [ -z \"$src\" ]; then\n          echo \"docker load produced no recognizable output\" >&2\n          exit 1\n        fi\n        docker tag \"$src\" \"$IMAGE_REPO:cached\"\n\n    - id: pull\n      shell: bash\n      if: inputs.dockerfile == '' && steps.cache.outputs.cache-hit != 'true'\n      env:\n        AGENT_IMAGE: ${{ steps.digest.outputs.image }}\n        IMAGE_REPO: ${{ inputs.image_repo }}\n      run: |\n        docker pull \"$AGENT_IMAGE\"\n        # Tag before save: docker save on a digest-only reference loses the\n        # name on load, leaving a dangling image ID that docker run can't\n        # resolve by @sha256. Tagging gives the tar a stable local ref.\n        docker tag \"$AGENT_IMAGE\" \"$IMAGE_REPO:cached\"\n        docker save \"$IMAGE_REPO:cached\" > /tmp/autopilot-ws.tar\n\n    # --- Run --------------------------------------------------------------\n    - id: run\n      shell: bash\n      env:\n        AGENT_IMAGE: ${{ inputs.image_repo }}:cached\n        CMD: ${{ inputs.command }}\n      run: bash \"$GITHUB_ACTION_PATH/../../scripts/run-in-docker-no-claude.sh\" \"$CMD\"\n", "userModified": false}, "tool_use_id": "toolu_01QyySxVh2X7k33QtufxNvem", "duration_ms": 16}}
{"timestamp": "2026-04-24T15:08:13.775131", "event": "Write", "data": {"session_id": "b6280e45-69a0-4be3-81ec-a2d05890506f", "transcript_path": "/home/node/.claude/projects/-workspace/b6280e45-69a0-4be3-81ec-a2d05890506f.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/workflows/check-constraints.yml", "content": "name: Check Constraints\n\n# Reusable workflow: pairs ensure-docker-image with the dumb check-constraints\n# runner. Consumers get two explicit, visible steps in the run graph:\n# 1) image preparation (with cache hit/miss legible), 2) the constraint check.\n# Consumers that want the flat run-graph form can bypass this shim and wire\n# both actions themselves.\non:\n  workflow_call:\n    inputs:\n      submodules:\n        description: |\n          Forwarded to actions/checkout. Set to \"true\" or \"recursive\" when\n          project.k.json declares specs inside submodule paths; otherwise\n          those spec.k.json files will be missing at constraint-check time.\n        required: false\n        type: string\n        default: \"\"\n      dockerfile:\n        description: |\n          Optional Dockerfile path. When unset, the check runs against\n          ghcr.io/clockwork-pilot/autopilot-ws as-is. When set, a derived\n          image is built and used instead. The Dockerfile must FROM an\n          autopilot-ws-compatible base.\n        required: false\n        type: string\n        default: \"\"\n      build_args:\n        description: Newline-separated KEY=VALUE build args, forwarded to ensure-docker-image.\n        required: false\n        type: string\n        default: \"\"\n      cache_key_prefix:\n        description: |\n          REQUIRED. Namespace for the image cache. See\n          .github/actions/ensure-docker-image/README.md for guidelines.\n          Use e.g. `${{ github.repository }}-check-img`.\n        required: true\n        type: string\n\njobs:\n  check-constraints:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n        with:\n          submodules: ${{ inputs.submodules }}\n\n      - id: image\n        uses: Clockwork-Pilot/autopilot/.github/actions/ensure-docker-image@main\n        with:\n          dockerfile:       ${{ inputs.dockerfile }}\n          build_args:       ${{ inputs.build_args }}\n          base_image:       ghcr.io/clockwork-pilot/autopilot-ws:latest\n          tag:              autopilot-check\n          cache_key_prefix: ${{ inputs.cache_key_prefix }}\n\n      - uses: Clockwork-Pilot/autopilot/.github/actions/check-constraints@main\n        with:\n          image: ${{ steps.image.outputs.image }}\n"}, "tool_use_id": "toolu_01A6FSnuUXRShy3bs4L1BKax"}}
