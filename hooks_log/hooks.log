{"timestamp": "2026-04-26T12:29:29.909908", "event": "Write", "data": {"session_id": "7a1f01a6-1a9b-4c52-a425-29713aa330f7", "transcript_path": "/home/node/.claude/projects/-workspace/7a1f01a6-1a9b-4c52-a425-29713aa330f7.jsonl", "cwd": "/workspace", "permission_mode": "bypassPermissions", "hook_event_name": "PreToolUse", "tool_name": "Write", "tool_input": {"file_path": "/workspace/autopilot/.github/actions/ensure-image-local/action.yml", "content": "name: Ensure Image (self-hosted runner)\ndescription: |\n  Prepare a local docker image tag on a self-hosted runner. The docker daemon's\n  persistent layer cache is reused across runs, so no external GHA cache is\n  needed. Idempotent: if a local tag with the computed content hash already\n  exists, build/pull is skipped entirely.\n\n  Two paths:\n    - dockerfile unset  \u2192 pulls `base_image`, tags it locally.\n    - dockerfile set    \u2192 builds the Dockerfile on top of `base_image`.\n\n  Use this action when `runs-on: [self-hosted, ...]`.\n  For GitHub-hosted runners use ensure-image-hosted instead.\n\ninputs:\n  dockerfile:\n    description: Path to the Dockerfile, relative to $GITHUB_WORKSPACE. Leave empty to only pull+tag `base_image`.\n    required: false\n    default: \"\"\n  context:\n    description: Build context directory, relative to $GITHUB_WORKSPACE. Only used when `dockerfile` is set.\n    required: false\n    default: \".\"\n  build_args:\n    description: Newline-separated KEY=VALUE build args, forwarded to the builder. Included in the content hash, so a change invalidates the local tag.\n    required: false\n    default: \"\"\n  base_image:\n    description: Image reference to pull and tag locally, and the FROM contract for any Dockerfile.\n    required: true\n  tag_prefix:\n    description: |\n      REQUIRED. Project namespace. The produced local tag is `<tag_prefix>:<hash>`,\n      so this is what `docker images` shows in the REPOSITORY column. Multiple\n      projects sharing one daemon (typical on a per-user self-hosted runner) keep\n      their tags partitioned because each project picks a distinct prefix.\n    required: true\n\noutputs:\n  image:\n    description: Fully qualified local tag of the produced image.\n    value: ${{ steps.finalize.outputs.image }}\n  cache_hit:\n    description: '\"true\" if the local tag pre-existed and neither build nor pull ran.'\n    value: ${{ steps.finalize.outputs.cache_hit }}\n  digest:\n    description: Local image ID (sha256) of the produced image.\n    value: ${{ steps.finalize.outputs.digest }}\n\nruns:\n  using: composite\n  steps:\n    - id: base\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n      run: |\n        set -euo pipefail\n        DIGEST=$(docker manifest inspect \"$BASE\" 2>/dev/null | sha256sum | cut -c1-16) || DIGEST=\"\"\n        if [ -z \"$DIGEST\" ]; then\n          docker pull \"$BASE\" >/dev/null\n          DIGEST=$(docker inspect --format='{{.Id}}' \"$BASE\" | sed 's/^sha256://' | cut -c1-16)\n        fi\n        echo \"digest=$DIGEST\" >> \"$GITHUB_OUTPUT\"\n\n    - id: key\n      shell: bash\n      env:\n        DOCKERFILE:  ${{ inputs.dockerfile }}\n        BUILD_ARGS:  ${{ inputs.build_args }}\n        BASE_DIGEST: ${{ steps.base.outputs.digest }}\n        PREFIX:      ${{ inputs.tag_prefix }}\n      run: |\n        set -euo pipefail\n        if [ -z \"$PREFIX\" ]; then\n          echo \"::error::tag_prefix is required\"\n          exit 1\n        fi\n        SAFE_PREFIX=$(printf '%s' \"$PREFIX\" | tr '/ ' '__' | tr '[:upper:]' '[:lower:]')\n        if [ -z \"$DOCKERFILE\" ]; then\n          HASH=\"base-${BASE_DIGEST}\"\n        else\n          DF_HASH=$(sha256sum \"$DOCKERFILE\" | cut -c1-16)\n          ARG_HASH=$(printf '%s' \"$BUILD_ARGS\" | sha256sum | cut -c1-16)\n          HASH=\"${DF_HASH}-${BASE_DIGEST}-${ARG_HASH}\"\n        fi\n        echo \"tag=${SAFE_PREFIX}:${HASH}\" >> \"$GITHUB_OUTPUT\"\n\n    - id: local\n      shell: bash\n      env:\n        TAG: ${{ steps.key.outputs.tag }}\n      run: |\n        if docker image inspect \"$TAG\" >/dev/null 2>&1; then\n          echo \"hit=true\"  >> \"$GITHUB_OUTPUT\"\n        else\n          echo \"hit=false\" >> \"$GITHUB_OUTPUT\"\n        fi\n\n    # PATH A \u2014 pull+tag base\n    - name: Pull base image\n      if: inputs.dockerfile == '' && steps.local.outputs.hit != 'true'\n      shell: bash\n      env:\n        BASE: ${{ inputs.base_image }}\n        TAG:  ${{ steps.key.outputs.tag }}\n      run: |\n        set -euo pipefail\n        docker pull \"$BASE\"\n        docker tag \"$BASE\" \"$TAG\"\n\n    # PATH B \u2014 build Dockerfile on top of base\n    - if: inputs.dockerfile != '' && steps.local.outputs.hit != 'true'\n      uses: docker/setup-buildx-action@4d04d5d9486b7bd6fa91e7baf45bbb4f8b9deedd\n\n    - name: Build with daemon layer cache\n      if: inputs.dockerfile != '' && steps.local.outputs.hit != 'true'\n      uses: docker/build-push-action@bcafcacb16a39f128d818304e6c9c0c18556b85f\n      with:\n        context:    ${{ inputs.context }}\n        file:       ${{ inputs.dockerfile }}\n        build-args: ${{ inputs.build_args }}\n        tags:       ${{ steps.key.outputs.tag }}\n        load:       true\n        push:       false\n\n    - id: finalize\n      shell: bash\n      env:\n        TAG:       ${{ steps.key.outputs.tag }}\n        LOCAL_HIT: ${{ steps.local.outputs.hit }}\n      run: |\n        set -euo pipefail\n        DIGEST=$(docker inspect --format='{{.Id}}' \"$TAG\")\n        {\n          echo \"image=$TAG\"\n          echo \"cache_hit=$LOCAL_HIT\"\n          echo \"digest=$DIGEST\"\n        } >> \"$GITHUB_OUTPUT\"\n"}, "tool_use_id": "toolu_01K3hL6WPmXAerbyaqVav4sT"}}
