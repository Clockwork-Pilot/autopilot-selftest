d:\n        description: 'Step (job) id to run from the target workflow'\n        required: true\n        type: string\n      inputs_json:\n        description: 'JSON payload of inputs for the step'\n        required: false\n        type: string\n        default: '{}'\n      artifact_path:\n        description: 'Base path for artifacts'\n        required: false\n        type: string\n        default: /tmp/act-artifacts\n\njobs:\n  executor:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n      - name: Dispatch\n        run: |\n          bash .github/scripts/test/act-step-dispatch.sh \"${{ inputs.workflow }}\" \"${{ inputs.step_id }}\" --inputs '${{ inputs.inputs_json }}' --artifact-server-path \"${{ inputs.artifact_path }}\"\n\n  # Composite-action test wrappers. Each job mirrors the env: shape of the\n  # original workflow job, so fixtures under .github/actions/<id>/fixtures/\n  # that key on expressions like \"needs.fetch-issue.outputs.title\" keep working\n  # when the test script targets `act-step-runner.yml <id>`. The run: step\n  # invokes the composite action's script directly (bypassing `uses:`), which\n  # is what act-step-dispatch.sh can execute.\n\n  parse-issue:\n    runs-on: ubuntu-latest\n    env:\n      TITLE:        ${{ needs.fetch-issue.outputs.title }}\n      BODY_RAW:     ${{ needs.fetch-issue.outputs.body_raw }}\n      ISSUE_NUMBER: ${{ inputs.issue_number }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n      - run: bash .github/actions/parse-issue/script.sh\n\n  choose-branch:\n    runs-on: ubuntu-latest\n    env:\n      PR_BRANCH:             ${{ needs.parse-issue.outputs.pr_branch }}\n      AGENT_BRANCH_DEFAULT:  ${{ needs.parse-issue.outputs.agent_branch_default }}\n      EXISTING_AGENT_BRANCH: ${{ needs.gather-repo-facts.outputs.existing_agent_branch }}\n      BASE_FROM_ISSUE:       ${{ needs.parse-issue.outputs.base_branch }}\n      DEFAULT_BRANCH:        ${{ needs.gather-repo-facts.outputs.default_branch }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n      - run: bash .github/actions/choose-branch/script.sh\n\n  parse-digest:\n    runs-on: ubuntu-latest\n    env:\n      MANIFEST_JSON: ${{ needs.fetch-manifest.outputs.manifest_json }}\n      IMAGE_REPO:    ${{ inputs.image_repo }}\n    steps:\n      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd\n      - run: bash .github/actions/parse-digest/script.sh\n", "structuredPatch": [{"oldStart": 59, "oldLines": 12, "newStart": 59, "newLines": 3, "lines": ["     steps:", "       - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd", "       - run: bash .github/actions/choose-branch/script.sh", "-", "-  parse-digest:", "-    runs-on: ubuntu-latest", "-    env:", "-      MANIFEST_JSON: ${{ needs.fetch-manifest.outputs.manifest_json }}", "-      IMAGE_REPO:    ${{ inputs.image_repo }}", "-    steps:", "-      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd", "-      - run: bash .github/actions/parse-digest/script.sh"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01QW31PXYQmwWrJK7VNvbTcu", "duration_ms": 17}}
